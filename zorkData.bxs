        "exits"       : {
            "up"    : { "blocked" : "There is no tree here suitable for climbing." },
            "east"  : "canyon_view",
            "north" : "forest_2",
            "south" : "forest_3",
            "west"  : "behind_house"
        }
    },

    "kitchen" : {
        "id"          : "kitchen",
        "name"        : "Kitchen",
        "dynamicDescription" : (allObjects) => {
            var windowState = allObjects.kitchen_window.open ? "open." : "slightly ajar.";
            return "You are in the kitchen of the white house. A table seems to
have been used recently for the preparation of food. A passage
leads to the west and a dark staircase can be seen leading
upward. A dark chimney leads down and to the east is a small
window which is " & windowState;
        },
        "exits"       : {
            "east"  : { "to" : "behind_house", "requiresOpen" : "kitchen_window" },
            "out"   : { "to" : "behind_house", "requiresOpen" : "kitchen_window" },
            "west"  : "living_room",
            "up"    : "attic",
            // DOWN TO STUDIO IF FALSE-FLAG: FALSE-FLAG is always false in
            // source (dead exit) — chimney is permanently impassable here.
            "down"  : { "blocked" : "Only Santa Claus climbs down chimneys." }
        }
    },

    "attic" : {
        "id"          : "attic",
        "name"        : "Attic",
        "description" : "This is the attic. The only exit is a stairway leading down.",
        "exits"       : {
            "down" : "kitchen"
        }
    },

    "living_room" : {
        "id"          : "living_room",
        "name"        : "Living Room",
        // Matches LIVING-ROOM-FCN's branching exactly: doorway text depends
        // on magicFlag, and the rug/trap-door clause depends on rugMoved
        // and the trap door's open state.
        "dynamicDescription" : (allObjects) => {
            var text = "You are in the living room. There is a doorway to the east";
            text &= gameState.flags.magicFlag ?
". To the
west is a cyclops-shaped opening in an old wooden door, above which is
some strange gothic lettering, " :
", a wooden
door with strange gothic lettering to the west, which appears to be
nailed shut, ";
            text &= "a trophy case, ";
            if ( gameState.flags.rugMoved && allObjects.trap_door.open ) {
                text &= "and a rug lying beside an open trap door.";
            } else if ( gameState.flags.rugMoved ) {
                text &= "and a closed trap door at your feet.";
            } else if ( allObjects.trap_door.open ) {
                text &= "and an open trap door at your feet.";
            } else {
                text &= "and a large oriental rug in the center of the room.";
            }
            return text;
        },
        "exits"       : {
            "east" : "kitchen",
            "west" : { "to" : "strange_passage", "requiresFlag" : "magicFlag", "blockedMessage" : "The door is nailed shut." },
            "down" : { "to" : "cellar", "requiresOpen" : "trap_door", "blockedMessage" : "You can't go that way." }
        }
    },

