    // ZIL's GRATING-CLEARING (DESC "Clearing", distinct from CLEARING below).
    "grating_clearing" : {
        "id"          : "grating_clearing",
        "name"        : "Clearing",
        "dynamicDescription" : (allObjects) => {
            var text = "You are in a clearing, with a forest surrounding you on all sides. A
path leads south.";
            if ( allObjects.grate.open ) {
                text &= NEWLINE & "There is an open grating, descending into darkness.";
            } else if ( gameState.flags.grateRevealed ) {
                text &= NEWLINE & "There is a grating securely fastened into the ground.";
            }
            return text;
        },
        "exits"       : {
            "north" : { "blocked" : "The forest becomes impenetrable to the north." },
            "east"  : "forest_2",
            "west"  : "forest_1",
            "south" : "path",
            "down"  : { "per" : "grating_exit" }
        }
