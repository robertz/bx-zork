// Zork I content ported from the MIT-licensed ZIL source at
// https://github.com/historicalsource/zork1 (1dungeon.zil, 1actions.zil).
// Full room map and object set. Descriptions/synonyms/flags are taken
// verbatim from the source; anything conditional on later game state or
// tied to a puzzle that isn't implemented yet is noted via a `note` field
// rather than silently dropped or invented (see project tasks for what's
// tracked as separate follow-on work: verb grammar, combat, set-piece
// puzzles, scoring/endgame).

function makeObject(id, name, synonyms, desc, takeable, options = {}) {
    return {
        "id"          : id,
        "name"        : name,
        "synonyms"    : synonyms,
        "adjectives"  : options.adjectives ?: [],
        "desc"        : desc,
        "takeable"    : takeable,
        "scenery"     : options.scenery ?: false,
        "container"   : options.container ?: false,
        "open"        : options.open ?: false,
        "openable"    : options.openable ?: false,
        "openMessage" : options.openMessage ?: "",
        "closeMessage": options.closeMessage ?: "",
        "noOpenMessage": options.noOpenMessage ?: "",
        "transparent" : options.transparent ?: false,
        "capacity"    : options.capacity ?: 0,
        "door"        : options.door ?: false,
        "light"       : options.light ?: false,
        // Current lit/burning state (ZIL's ONBIT) for light/flame sources —
        // distinct from `open`, which is about containers/doors.
        "on"          : options.on ?: false,
        "readable"    : options.readable ?: false,
        "text"        : options.text ?: "",
        "noTakeMessage": options.noTakeMessage ?: "",
        "globalIn"    : options.globalIn ?: [],
        "location"    : options.location ?: "",
        // ZIL's INVISIBLE flag: a real placement that isn't in scope yet
        // because its reveal trigger (a puzzle from the task list) isn't
        // wired up. Always paired with a `note` saying what should clear it.
        "hidden"      : options.hidden ?: false,
        "weapon"      : options.weapon ?: false,
        "tool"        : options.tool ?: false,
        "food"        : options.food ?: false,
        "burnable"    : options.burnable ?: false,
        "actor"       : options.actor ?: false,
        "strength"    : options.strength ?: 0,
        "value"       : options.value ?: 0,
        "treasureValue" : options.treasureValue ?: 0,
        "size"        : options.size ?: 0,
        "climbable"   : options.climbable ?: false,
        "drinkable"   : options.drinkable ?: false,
        "locked"      : options.locked ?: false,
        "unlocksWith" : options.unlocksWith ?: "",
        "note"        : options.note ?: ""
    };
}

