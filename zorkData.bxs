    // --- Cyclops and the hideaway ----------------------------------------

    "cyclops_room" : {
        "id" : "cyclops_room", "name" : "Cyclops Room",
        // Simplified from CYCLOPS-ROOM-FCN: the source also tracks
        // CYCLOWRATH (an anger meter from feeding it hot peppers) with two
        // extra description variants — not modeled, defaults to "present".
        "dynamicDescription" : () => {
            var text = "This room has an exit on the northwest, and a staircase leading up.";
            if ( gameState.flags.cyclopsFlag && !gameState.flags.magicFlag ) {
                text &= NEWLINE & "The cyclops is sleeping blissfully at the foot of the stairs.";
            } else if ( gameState.flags.magicFlag ) {
                text &= NEWLINE & "The east wall, previously solid, now has a cyclops-sized opening in it.";
            } else {
                text &= NEWLINE &
"A cyclops, who looks prepared to eat horses (much less mere
adventurers), blocks the staircase. From his state of health, and
the bloodstains on the walls, you gather that he is not very
friendly, though he likes people.";
            }
            return text;
        },
        "exits" : {
            "nw"   : "maze_15",
            "east" : { "to" : "strange_passage", "requiresFlag" : "magicFlag", "blockedMessage" : "The east wall is solid rock." },
            "up"   : { "to" : "treasure_room", "requiresFlag" : "cyclopsFlag", "blockedMessage" : "The cyclops doesn't look like he'll let you past." }
        }
    },

    "strange_passage" : {
        "id" : "strange_passage", "name" : "Strange Passage",
        "description" :
"This is a long passage. To the west is one entrance. On the
east there is an old wooden door, with a large opening in it (about
cyclops sized).",
        "exits" : { "west" : "cyclops_room", "in" : "cyclops_room", "east" : "living_room" }
    },

    "treasure_room" : {
        "id" : "treasure_room", "name" : "Treasure Room",
        // TREASURE-ROOM-FCN also handles the Thief's lair/combat dynamics
        // (Task 5 — not implemented yet); static LDESC shown unconditionally.
        "description" :
"This is a large room, whose east wall is solid granite. A number
of discarded bags, which crumble at your touch, are scattered about
on the floor. There is an exit down a staircase.",
        "exits" : { "down" : "cyclops_room" }
    },

    // --- Reservoir area ---------------------------------------------------

    "reservoir_south" : {
        "id" : "reservoir_south", "name" : "Reservoir South",
        // Simplified from RESERVOIR-SOUTH-FCN: source has a 4-way
        // (full lake / draining / refilling / drained) description; the
        // transitional GATES-OPEN states aren't modeled, just the two
        // steady states.
        "dynamicDescription" : () => {
            var text = gameState.flags.lowTide ?
"You are in a long room, to the north of which is a wide area which
was formerly a reservoir, but now is merely a stream. You notice,
however, that the level of the stream is rising quickly and that
before long it will be impossible to cross here." :
"You are in a long room on the south shore of a large lake, far
too deep and wide for crossing.";
            return text & NEWLINE &
"There is a path along the stream to the east or west, a steep pathway
climbing southwest along the edge of a chasm, and a path leading into a
canyon to the southeast.";
        },
        "exits" : {
            "se"   : "deep_canyon",
            "sw"   : "chasm_room",
            "east" : "dam_room",
            "west" : "stream_view",
            "north" : { "to" : "reservoir", "requiresFlag" : "lowTide", "blockedMessage" : "You would drown." }
        }
    },

    "reservoir" : {
        "id" : "reservoir", "name" : "Reservoir",
        "dynamicDescription" : () => gameState.flags.lowTide ?
"You are on what used to be a large lake, but which is now a large
mud pile. There are ""shores"" to the north and south." :
"You are on the lake. Beaches can be seen north and south.
Upstream a small stream enters the lake through a narrow cleft
in the rocks. The dam can be seen downstream.",
        "exits" : {
            "north" : "reservoir_north",
