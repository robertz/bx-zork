// BoxLang Zork-style command parser/engine.
// Pipeline: tokenize -> classify -> grammar match -> resolve against scope -> dispatch.

include "zorkData.bxs";

NEWLINE = "
";

NOISE_WORDS = [ "a", "an", "the" ];

// Words that split a two-object sentence ("put X in Y", "give X to Y") into
// its direct and indirect object phrases. Several of these double as
// DIRECTION_WORDS ("in", "on" isn't, but "in"/"out" are); that's fine —
// extractVerb()/processCommand only consult DIRECTION_WORDS for a bare
// leading direction or after "go", so there's no ambiguity in practice.
PREPOSITION_WORDS = [ "in", "into", "on", "onto", "under", "behind", "with", "to", "from", "through", "at", "off" ];

DIRECTION_WORDS = {
    "north" : "north", "n" : "north",
    "south" : "south", "s" : "south",
    "east"  : "east",  "e" : "east",
    "west"  : "west",  "w" : "west",
    "ne" : "ne", "northeast" : "ne",
    "nw" : "nw", "northwest" : "nw",
    "se" : "se", "southeast" : "se",
    "sw" : "sw", "southwest" : "sw",
    "up" : "up", "u" : "up",
    "down" : "down", "d" : "down",
    "in" : "in", "enter" : "in",
    "out" : "out", "exit" : "out",
    // ZIL's LAND is its own verb/direction (the boat's "go ashore" command),
    // distinct from a compass direction — see the boat label's instructions
    // and RIVER-LAUNCH/RBOAT-FUNCTION's M-BEG WALK handling for P?LAND.
    "land" : "land"
};

// IT/HIM/HER/THEM all collapse onto the single last-referenced-object
// pointer below — this engine has no object-gender data to split ZIL's
// separate IT/HIM/HER parser slots on, but this covers the common case
// ("take lamp. turn it on.").
PRONOUNS = [ "it", "him", "her", "them" ];

// ZIL's MANY/SMANY grammar bit (ALL/ALL BUT and "X and Y" object lists) is
// per-verb; this port scopes it to the two verbs players hit it on most.
MULTI_OBJECT_VERBS = [ "take", "drop" ];

// Verbs taking no object at all.
ZERO_OBJECT_VERBS = [ "look", "inventory", "pray", "score", "diagnose", "launch", "odysseus", "save" ];

// Verbs taking exactly one object (an empty noun phrase is an error, except
// "smell"/"listen" which are handled separately since they're valid with or
// without one).
ONE_OBJECT_VERBS = [
    "examine", "take", "drop", "open", "close", "read", "drink", "eat", "climb",
    "wave", "ring", "wind", "push", "board", "search", "light", "extinguish",
    "turn_on", "turn_off", "raise", "lower",
    "kick", "cut", "look_under", "follow", "wake", "answer"
];

// Verbs taking a direct object and an optional/required indirect object,
// split out of the sentence at the first matching preposition (ZIL's
// grammar table pins one specific preposition per verb; this matches that).
TWO_OBJECT_VERBS = {
    "give"    : { "prepositions" : [ "to" ],                      "requireSecond" : true,  "prompt" : "Give it to whom?" },
    "put"     : { "prepositions" : [ "in", "into", "on", "onto" ], "requireSecond" : true,  "prompt" : "Put it in or on what?" },
    "tie"     : { "prepositions" : [ "to" ],                      "requireSecond" : true,  "prompt" : "Tie it to what?" },
    "unlock"  : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "lock"    : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "pour"    : { "prepositions" : [ "on", "onto", "in", "into" ], "requireSecond" : false },
    "fill"    : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "inflate" : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "burn"    : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "dig"     : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "turn"    : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "attack"  : { "prepositions" : [ "with" ],                    "requireSecond" : false },
    "throw"   : { "prepositions" : [ "at" ],                      "requireSecond" : false },
    "rub"     : { "prepositions" : [ "with" ],                    "requireSecond" : false }
};

VERB_SYNONYMS = {
    "look"       : [ "look", "l" ],
    "inventory"  : [ "inventory", "i", "inv" ],
    "examine"    : [ "examine", "x", "inspect", "look at" ],
    "take"       : [ "take", "get", "grab" ],
    "drop"       : [ "drop" ],
    "open"       : [ "open" ],
    "close"      : [ "close", "shut" ],
    "read"       : [ "read" ],
    "go"         : [ "go", "walk" ],
    "drink"      : [ "drink", "sip" ],
    "eat"        : [ "eat" ],
    "climb"      : [ "climb", "scale" ],
    "dig"        : [ "dig" ],
    "pray"       : [ "pray" ],
    "pour"       : [ "pour" ],
    "fill"       : [ "fill" ],
    "wave"       : [ "wave", "shake" ],
    "ring"       : [ "ring" ],
    "wind"       : [ "wind" ],
    "tie"        : [ "tie", "attach" ],
    "inflate"    : [ "inflate" ],
    "board"      : [ "board" ],
    "launch"     : [ "launch" ],
    "unlock"     : [ "unlock" ],
    "lock"       : [ "lock" ],
    "push"       : [ "push", "move", "shove" ],
    "search"     : [ "search" ],
    "smell"      : [ "smell", "sniff" ],
    "listen"     : [ "listen" ],
    "diagnose"   : [ "diagnose" ],
    "score"      : [ "score" ],
    "odysseus"   : [ "odysseus", "ulysses" ],
    "give"       : [ "give", "offer" ],
    "put"        : [ "put", "place", "insert" ],
    "attack"     : [ "attack", "kill", "hit", "fight" ],
    "light"      : [ "light" ],
    "burn"       : [ "burn" ],
    "extinguish" : [ "extinguish", "douse" ],
    "turn_on"    : [ "turn on" ],
    "turn_off"   : [ "turn off" ],
    "turn"       : [ "turn", "rotate" ],
    "raise"      : [ "raise", "lift" ],
    "lower"      : [ "lower" ],
    "rub"        : [ "rub" ],
    "throw"      : [ "throw", "hurl", "chuck", "toss" ],
    "save"       : [ "save" ],
    "kick"       : [ "kick", "taunt" ],
    "cut"        : [ "cut", "slice", "pierce" ],
    "look_under" : [ "look under" ],
    "follow"     : [ "follow", "pursue", "chase", "come" ],
    "wake"       : [ "wake", "wake up", "awake", "surprise", "startle" ],
    "answer"     : [ "answer", "reply" ]
};

gameState = {
    "currentRoom" : startRoomId,
    "turns" : 0,
    // Mirrors the boolean globals in 1dungeon.zil/1actions.zil that gate
    // exits. All default false (their ZIL default), and get flipped either
    // here (rugMoved, domeFlag, lowTide — Task 3's simple single-trigger
    // mechanics) or by puzzle logic that isn't implemented yet (tracked
    // separately) — until then, every exit depending on one of those stays
    // realistically blocked, exactly like a fresh game in progress.
    "flags" : {
        "wonFlag"       : false, // all treasures deposited -> endgame barrow
        "trollFlag"     : false, // troll killed
        "lowTide"       : false, // reservoir drained via the dam control bolt
        "cyclopsFlag"   : false, // cyclops has fled
        "magicFlag"     : false, // exorcism ceremony completed
        "lldFlag"       : false, // ghosts banished from Hades gate
        "coffinCure"    : false, // curse of the coffin lifted via prayer
        "domeFlag"      : false, // rope tied to the dome railing
        "rainbowFlag"   : false, // rainbow made solid via the sceptre
        "grateRevealed" : false, // grating spotted from below in the maze
        "rugMoved"      : false, // rug pushed aside, revealing the trap door
        "cageTop"       : true,  // CAGE-TOP: dumbwaiter basket currently at the shaft top
        "songSung"      : false, // SING-SONG: canary already wound in a forest room, bauble dropped
        "mirrorBroken"  : false, // MIRROR-MUNG: mirror smashed, disabling MIRROR-MIRROR teleport for both rooms
        "gateFlag"      : false, // GATE-FLAG: yellow button pushed, bolt now turns (bubble glows)
        "gatesOpen"     : false, // GATES-OPEN: sluice gates currently open (lowTide follows 8 turns later)
        "ghost"         : false  // DEAD: died after visiting the Altar — ghost-limbo until PRAY there
    },
    // I-RFILL/I-REMPTY: turns left until the reservoir actually finishes
    // draining/refilling after the bolt is turned (0 = no transition in
    // progress). Decremented by tickDam(); when it hits 0, lowTide flips to
    // match gatesOpen.
    "gatesTransitionTurns" : 0,
    // WATER-LEVEL: maintenance room flood level. 0 (the ZIL default) means
    // "leak not started yet" — the only state in which the blue button
    // still works; pushing it sets this to 1 and starts tickMaintRoom()'s
    // countdown. FIX-MAINT-LEAK sets it to -1 ("patched"), which is
    // deliberately *not* 0 again — exactly like ZIL, the blue button is a
    // one-shot: pushing it again after a fix still reports "jammed".
    "waterLevel" : 0,
    // MUNG-ROOM's effect on the Maintenance Room: once true, the room is
    // permanently flooded and can no longer be entered.
    "maintenanceFlooded" : false,
    // Combat (FIGHT-STRENGTH's P?STRENGTH adjustment on the player —
    // negative while wounded, recovering over time via tickCure()/CURE_WAIT,
    // exactly like ZIL's I-CURE demon).
    "playerStrengthAdjustment" : 0,
    // I-CURE: turns left until the next 1-point heal fires (0 = demon
    // disabled, i.e. not currently wounded). Reset to CURE_WAIT every time
    // a blow actually wounds the player; re-armed after each heal as long
    // as playerStrengthAdjustment is still negative.
    "cureTimer" : 0,
    "playerDead" : false,
    "gameWon" : false,
    // DEATHS: successful resurrections so far (JIGS-UP). The first
    // DEATH_LIMIT deaths cost 10 points and respawn you in Forest-1 at
    // FIGHT-STRENGTH 1; past that, death is permanent (see endGame()).
    "deaths" : 0,
    // BASE-SCORE: one-time points banked the moment a treasure is first
    // taken (object.value, zeroed after scoring so it can't repeat). Added
    // to the trophy case's live TVALUE total to get the real ,SCORE — see
    // handleScoreValue().
    "baseScore" : 0,
    // BEACH-DIG: consecutive digs-with-shovel counter in the Sandy Cave
    // (handleDig). -1 means "not currently digging a hole".
    "beachDig" : -1,
    // Id of the boat currently carrying the player ("inflated_boat" once
    // launched), or "" when on foot. Mirrors ZIL's VEHBIT check (<LOC ,WINNER>
    // being the vehicle rather than a room) used to gate river travel and the
    // BOARD/WALK/LAUNCH grammar in RBOAT-FUNCTION.
    "boardedVehicle" : "",
    // Set by handleLaunch() for the turn it's called on, so tickRiver()
    // doesn't also drift the boat downstream the same turn it enters the
    // river (see I-RIVER's queue timing in 1actions.zil).
    "skipRiverDriftThisTurn" : false,
    // MATCH-COUNT: matches remaining in the matchbook (handleStrikeMatch).
    "matchCount" : 6,
    // GRUE-FUNCTION's turn counter: increments each turn you spend in
    // darkness, resets to 0 when you re-enter light. The grue first fires
    // after 2 dark turns (matching ZIL's INT-DEF I-GRUE delay of 2).
    "grueCounter" : 0,
    // P-IT-OBJECT-equivalent: last object successfully referenced by name,
    // for IT/HIM/HER/THEM (see PRONOUNS). lastObjectIds is the plural form,
    // set by ALL/"X and Y" resolution (see resolveObjectGroup()).
    "lastObjectId" : "",
    "lastObjectIds" : [],
    // Raw text of the last fully-dispatched command line, for AGAIN/G and
    // for OOPS to rebuild the sentence around a corrected word.
    "lastRawInput" : "",
    // The most recent word that failed vocabulary lookup, so "oops <word>"
    // knows what to replace in lastRawInput.
    "lastUnknownWord" : "",
    // ORPHANING/disambiguation (ZIL's GET-OBJECT/WHICH-PRINT): when a verb
    // is missing a required object, or a noun phrase matches more than one
    // visible object, the question is asked here and the *next* input line
    // is consumed as the answer rather than parsed as a fresh command. See
    // resolvePendingPromptTurn(). type == "" means no question pending.
    "pendingPrompt" : { "type" : "" }
};

function clearPendingPrompt() {
    gameState.pendingPrompt = { "type" : "" };
}

function buildVerbIndex() {
    var index = {};
    for ( var canonical in VERB_SYNONYMS ) {
        for ( var synonym in VERB_SYNONYMS[ canonical ] ) {
            index[ synonym ] = canonical;
        }
    }
    return index;
}

function buildVocabulary(allObjects) {
    var nounIndex = {};
    var adjectiveIndex = {};
    for ( var objectId in allObjects ) {
        var obj = allObjects[ objectId ];
        for ( var synonym in obj.synonyms ) {
            var word = synonym.lcase();
            if ( !nounIndex.keyExists( word ) ) {
                nounIndex[ word ] = [];
            }
            nounIndex[ word ].append( objectId );
        }
        for ( var adjective in obj.adjectives ) {
            var adjWord = adjective.lcase();
            if ( !adjectiveIndex.keyExists( adjWord ) ) {
                adjectiveIndex[ adjWord ] = [];
            }
            adjectiveIndex[ adjWord ].append( objectId );
        }
    }
    return { "nouns" : nounIndex, "adjectives" : adjectiveIndex };
}

VERB_INDEX  = buildVerbIndex();
VOCABULARY  = buildVocabulary( objects );

// Treasures whose only route is gated on a flag that computeTreasureMaxScore()
// can't detect just by checking `hidden`/`location` (those cases are excluded
// automatically below). Empty for now — kept around for the next puzzle that
// turns out to need this treatment.
UNREACHABLE_TREASURES = [];

// Treasures that start `hidden`/unplaced (so the generic check below would
// otherwise skip them) but whose reveal puzzle is now implemented and is
// always worth pursuing: trunk (reservoir drain), scarab (dig), pot_of_gold
// (wave sceptre), diamond (coal machine). Deliberately NOT listed:
// broken_egg/broken_canary/bauble — winding the canary or breaking the egg
// nets fewer points than leaving them intact (they have little/no value of
// their own), so the optimal-play max never goes through them.
FORCE_REACHABLE_TREASURES = [ "trunk", "scarab", "pot_of_gold", "diamond" ];

// Highest ,SCORE reachable under the treasures currently ported (take
// value + deposit value, summed before anything is taken/deposited and
// mutated) — and also the win-condition threshold (see
// checkEndgameTrigger()). The original totals 350; this is whatever's
// actually obtainable with what's wired up so far under optimal play.
function computeTreasureMaxScore(allObjects) {
    var total = 0;
    for ( var id in allObjects ) {
        var obj = allObjects[ id ];
        var forced = FORCE_REACHABLE_TREASURES.contains( id );
        var normallyReachable = !obj.hidden && obj.location.len();
        if ( UNREACHABLE_TREASURES.contains( id ) || !( forced || normallyReachable ) ) {
            continue;
        }
        total += obj.value + obj.treasureValue;
    }
    return total;
}

TREASURE_MAX_SCORE = computeTreasureMaxScore( objects );

function tokenize(input) {
    return reMatch( "[a-zA-Z']+", input.lcase() );
}

// Grammar match: pulls the verb off the front of a noise-stripped word
// list. Tries a two-word phrase first ("turn on", "turn off") so those
// don't get misread as the single-word "turn" (rotate) verb.
function extractVerb(words) {
    if ( words.len() >= 2 ) {
        var phrase = words[ 1 ] & " " & words[ 2 ];
        if ( VERB_INDEX.keyExists( phrase ) ) {
            return { "found" : true, "verb" : VERB_INDEX[ phrase ], "consumed" : 2 };
        }
    }
    if ( VERB_INDEX.keyExists( words[ 1 ] ) ) {
        return { "found" : true, "verb" : VERB_INDEX[ words[ 1 ] ], "consumed" : 1 };
    }
    return { "found" : false };
}

// array.slice(start, length) treats length <= 0 as "no limit" rather than
// zero elements (verified against the BoxLang runtime), so a thin wrapper
// is needed to get an actual empty array out of an empty range.
function sliceWords(words, start, count) {
    return count > 0 ? words.slice( start, count ) : [];
}

// ZIL's LIGHT-INT: room is lit if it has a natural LFLAG (outdoor/above-ground)
// or a lit, non-burned-out light source is in the room or carried by the player.
function roomIsLit() {
    // ALWAYS-LIT: a ghost's senses work regardless of light source or fuel.
    if ( gameState.flags.ghost ) {
        return true;
    }
    var room = rooms[ gameState.currentRoom ];
    if ( room.keyExists( "lit" ) && room.lit ) {
        return true;
    }
    for ( var id in objects ) {
        var obj = objects[ id ];
        if ( !obj.light || !obj.on || obj.burnedOut ) {
            continue;
        }
        if ( obj.location == "player" || obj.location == gameState.currentRoom ) {
            return true;
        }
    }
    return false;
}

// Objects visible/reachable right now: things located in the current room,
// things carried, the (open or transparent) contents of either, plus any
// scenery objects that declare the current room in their globalIn list.
// In darkness, only carried items are visible — room contents are unseen.
function getVisibleObjectIds(currentRoomId) {
    var visible = [];

    function addContainerContents(containerId) {
        var container = objects[ containerId ];
        if ( !( container.container && ( container.open || container.transparent ) ) ) {
            return;
        }
        for ( var objectId in objects ) {
            if ( objects[ objectId ].location == containerId && !objects[ objectId ].hidden ) {
                visible.append( objectId );
                addContainerContents( objectId );
            }
        }
    }

    if ( !roomIsLit() ) {
        for ( var objectId in objects ) {
            if ( objects[ objectId ].location == "player" && !objects[ objectId ].hidden ) {
                visible.append( objectId );
                addContainerContents( objectId );
            }
        }
        return visible;
    }

    for ( var objectId in objects ) {
        var obj = objects[ objectId ];
        if ( obj.hidden ) {
            continue;
        }
        if ( obj.location == currentRoomId || obj.location == "player" ) {
            visible.append( objectId );
            addContainerContents( objectId );
        } else if ( obj.globalIn.contains( currentRoomId ) ) {
            visible.append( objectId );
        }
    }

    return visible;
}

function article(name) {
    var vowels = [ "a", "e", "i", "o", "u" ];
    return vowels.contains( name.left( 1 ).lcase() ) ? "an" : "a";
}

// Resolves a noun phrase (verb already stripped) against the player's
// current scope. Returns either an object id (string) or a struct
// { "error" : "message" } if resolution failed.
// Builds ZIL's "Which do you mean, the X or the Y?" disambiguation prompt.
function buildDisambiguationQuestion(candidates) {
    var names = candidates.map( (id) => article( objects[ id ].name ) & " " & objects[ id ].name );
    if ( names.len() == 2 ) {
        return "Which do you mean, #names[ 1 ]# or #names[ 2 ]#?";
    }
    var head = names.slice( 1, names.len() - 1 ).toList( ", " );
    return "Which do you mean, #head#, or #names[ names.len() ]#?";
}

// Matches a disambiguation answer ("the brass one", "lamp") against the
// candidate set by synonym/adjective word overlap.
function matchAnswerAgainstCandidates(input, candidates) {
    var words = tokenize( input ).filter( (w) => !NOISE_WORDS.contains( w ) );
    if ( words.isEmpty() ) {
        return [];
    }
    // Score each candidate by how many input words it matches, then return
    // only those tied at the highest score — "trap door" beats "door" alone
    // for trap_door vs wooden_door because "trap" gives it an extra point.
    var scored = candidates.map( (id) => {
        var obj = objects[ id ];
        var lowerSynonyms = obj.synonyms.map( (s) => s.lcase() );
        var score = 0;
        for ( var w in words ) {
            if ( lowerSynonyms.contains( w ) || obj.adjectives.contains( w ) ) {
                score += 1;
            }
        }
        return { "id": id, "score": score };
    } ).filter( (entry) => entry.score > 0 );
    if ( scored.isEmpty() ) {
        return [];
    }
    var best = scored.reduce( (acc, entry) => entry.score > acc ? entry.score : acc, 0 );
    return scored.filter( (entry) => entry.score == best ).map( (entry) => entry.id );
}

function resolveObject(words, currentRoomId) {
    var meaningful = words.filter( (w) => !NOISE_WORDS.contains( w ) );
    if ( meaningful.isEmpty() ) {
        return { "error" : "Be more specific." };
    }

    // Pronoun shortcut (IT/HIM/HER/THEM) — see PRONOUNS.
    if ( meaningful.len() == 1 && PRONOUNS.contains( meaningful[ 1 ] ) ) {
        if ( !gameState.lastObjectId.len() ) {
            return { "error" : "I don't know what you're referring to." };
        }
        if ( !getVisibleObjectIds( currentRoomId ).contains( gameState.lastObjectId ) ) {
            return { "error" : "You don't see that here." };
        }
        return gameState.lastObjectId;
    }

    var headNoun = meaningful[ meaningful.len() ];
    var requiredAdjectives = meaningful.len() > 1 ? meaningful.slice( 1, meaningful.len() - 1 ) : [];

    if ( !VOCABULARY.nouns.keyExists( headNoun ) ) {
        gameState.lastUnknownWord = headNoun;
        return { "error" : "I don't know the word ""#headNoun#""." };
    }

    var globalCandidates = VOCABULARY.nouns[ headNoun ];
    var visibleIds = getVisibleObjectIds( currentRoomId );

    var candidates = globalCandidates.filter( (id) => visibleIds.contains( id ) );

    if ( requiredAdjectives.len() ) {
        candidates = candidates.filter( (id) => {
            var obj = objects[ id ];
            for ( var adj in requiredAdjectives ) {
                if ( !obj.adjectives.contains( adj ) ) {
                    return false;
                }
            }
            return true;
        } );
    }

    if ( candidates.isEmpty() ) {
        return { "error" : "You don't see that here." };
    }
    if ( candidates.len() > 1 ) {
        return { "error" : buildDisambiguationQuestion( candidates ), "candidates" : candidates };
    }

    gameState.lastObjectId = candidates[ 1 ];
    return candidates[ 1 ];
}

// ALL/ALL BUT and "X and Y" object lists (ZIL's MANY/SMANY), scoped to
// MULTI_OBJECT_VERBS. Returns { "ids" : [...] } on success, { "error" : msg }
// on failure, or { "single" : true } when the words don't actually contain
// a list — callers fall through to ordinary single-object resolution.
function visibleAllCandidates(verb) {
    var visibleIds = getVisibleObjectIds( gameState.currentRoom );
    if ( verb == "drop" ) {
        return visibleIds.filter( (id) => objects[ id ].location == "player" );
    }
    return visibleIds.filter( (id) => objects[ id ].takeable && objects[ id ].location != "player" );
}

function resolveObjectGroup(words, verb) {
    if ( words.len() == 1 && words[ 1 ] == "them" && gameState.lastObjectIds.len() ) {
        return { "ids" : gameState.lastObjectIds };
    }

    if ( words.len() && words[ 1 ] == "all" ) {
        var excluded = [];
        var afterAll = sliceWords( words, 2, words.len() - 1 );
        if ( afterAll.len() >= 2 && [ "but", "except" ].contains( afterAll[ 1 ] ) ) {
            var excludePhrase = sliceWords( afterAll, 2, afterAll.len() - 1 );
            var excludedResolved = resolveObject( excludePhrase, gameState.currentRoom );
            if ( isSimpleValue( excludedResolved ) ) {
                excluded.append( excludedResolved );
            }
        }
        var allIds = visibleAllCandidates( verb ).filter( (id) => !excluded.contains( id ) );
        if ( allIds.isEmpty() ) {
            return { "error" : verb == "drop" ? "You aren't carrying anything." : "There's nothing here to take." };
        }
        return { "ids" : allIds };
    }

    var groups = [];
    var current = [];
    for ( var w in words ) {
        if ( w == "and" ) {
            if ( current.len() ) {
                groups.append( current );
            }
            current = [];
        } else {
            current.append( w );
        }
    }
    if ( current.len() ) {
        groups.append( current );
    }

    if ( groups.len() <= 1 ) {
        return { "single" : true };
    }

    var ids = [];
    for ( var group in groups ) {
        var resolved = resolveObject( group, gameState.currentRoom );
        // Ambiguity inside a multi-item list isn't resumable in this port
        // (would need to track partially-resolved siblings); surface it as
        // a flat failure rather than a half-wired clarifying question.
        if ( !isSimpleValue( resolved ) ) {
            return { "error" : resolved.error };
        }
        ids.append( resolved );
    }
    return { "ids" : ids };
}

// Room "contents" are never read off a static per-room list — every object
// carries its own authoritative `location`, so anything moved into a room
// (dropped, stolen and stashed, knocked down from a tree...) shows up here
// without the room definition needing to know about it.
function describeRoom(room) {
    var lines = [];
    lines.append( room.name );
    if ( !roomIsLit() ) {
        lines.append( "It is pitch black." );
        return lines.toList( NEWLINE );
    }
    lines.append( room.keyExists( "dynamicDescription" ) ? room.dynamicDescription( objects ) : room.description );

    var presentIds = objects.keyArray().filter( (id) => objects[ id ].location == room.id && !objects[ id ].scenery && !objects[ id ].hidden );
    for ( var objectId in presentIds ) {
        var obj = objects[ objectId ];
        lines.append( obj.desc.len() ? obj.desc : "There is #article( obj.name )# #obj.name# here." );
    }

    return lines.toList( NEWLINE );
}

function handleLook() {
    return describeRoom( rooms[ gameState.currentRoom ] );
}

function handleInventory() {
    var carried = objects.keyArray().filter( (id) => objects[ id ].location == "player" );
    if ( carried.isEmpty() ) {
        return "You are empty-handed.";
    }
    var names = carried.map( (id) => objects[ id ].name );
    return "You are carrying:" & NEWLINE & names.map( (n) => "  A " & n ).toList( NEWLINE );
}

function handleExamine(obj) {
    // MIRROR-MIRROR's LOOK-INSIDE/EXAMINE branch: reflects MIRROR-MUNG state.
    if ( [ "mirror_1", "mirror_2" ].contains( obj.id ) ) {
        return gameState.flags.mirrorBroken
            ? "The mirror is broken into many pieces."
            : "There is an ugly person staring back at you.";
    }
    var description = obj.desc.len() ? obj.desc : "There's nothing special about the #obj.name#.";
    if ( obj.container && ( obj.open || obj.transparent ) ) {
        var contents = objects.keyArray().filter( (id) => objects[ id ].location == obj.id && !objects[ id ].hidden );
        if ( contents.len() ) {
            description &= NEWLINE & "The #obj.name# contains:" & NEWLINE &
                contents.map( (id) => "  " & objects[ id ].name ).toList( NEWLINE );
        } else {
            description &= NEWLINE & "The #obj.name# is empty.";
        }
    } else if ( obj.door ) {
        description &= NEWLINE & ( obj.open ? "It is open." : "It is closed." );
    }
    return description;
}

function handleTake(obj) {
    if ( obj.location == "player" ) {
        return "You already have that.";
    }
    if ( !obj.takeable ) {
        return obj.noTakeMessage.len() ? obj.noTakeMessage : "You can't take that.";
    }
    obj.location = "player";
    if ( obj.value > 0 ) {
        gameState.baseScore += obj.value;
        obj.value = 0;
    }
    return "Taken.";
}

// BAD-EGG: the egg (FLAGS minus OPENBIT) is replaced by broken_egg in the
// same spot. Per ZIL, an intact canary nested inside goes down with it and
// becomes broken_canary (nested in broken_egg); otherwise broken_canary
// stays unplaced. Idempotent — calling this on an already-broken egg is a
// no-op so callers don't need to check first.
function breakEgg() {
    if ( objects.egg.location == "" ) {
        return;
    }
    var eggLocation = objects.egg.location;
    if ( objects.canary.location == "egg" ) {
        objects.canary.location = "";
        objects.broken_canary.location = "broken_egg";
        objects.broken_canary.hidden = false;
    }
    objects.egg.location = "";
    objects.broken_egg.location = eggLocation;
    objects.broken_egg.hidden = false;
}

function handleDrop(obj) {
    if ( obj.location != "player" ) {
        return "You don't have that.";
    }
    // TREE-ROOM's M-BEG DROP handler: dropping the egg (or the nest with the
    // egg still in it) from up the tree is the one ZIL-verbatim "fall and
    // break" case — ground-level drops elsewhere are just "Dropped.".
    if ( gameState.currentRoom == "up_a_tree" ) {
        if ( obj.id == "nest" && objects.egg.location == "nest" ) {
            obj.location = "path";
            breakEgg();
            return "The nest falls to the ground, and the egg spills out of it, seriously damaged.";
        }
        if ( obj.id == "egg" ) {
            obj.location = "path";
            breakEgg();
            return "The egg falls to the ground and springs open, seriously damaged.";
        }
    }
    obj.location = gameState.currentRoom;
    return "Dropped.";
}

function handleOpen(obj) {
    if ( !obj.openable ) {
        return obj.noOpenMessage.len() ? obj.noOpenMessage : "You can't open that.";
    }
    if ( obj.locked ) {
        return "It's locked.";
    }
    if ( obj.open ) {
        return "It's already open.";
    }
    obj.open = true;
    if ( obj.openMessage.len() ) {
        return obj.openMessage;
    }
    if ( obj.container ) {
        var contents = objects.keyArray().filter( (id) => objects[ id ].location == obj.id && !objects[ id ].hidden );
        if ( contents.len() ) {
            return "Opening the #obj.name# reveals " &
                contents.map( (id) => article( objects[ id ].name ) & " " & objects[ id ].name ).toList( ", " ) & ".";
        }
    }
    return "Opened.";
}

function handleClose(obj) {
    if ( !obj.openable ) {
        return "You can't close that.";
    }
    if ( !obj.open ) {
        return "It's already closed.";
    }
    obj.open = false;
    return obj.closeMessage.len() ? obj.closeMessage : "Closed.";
}

function handleRead(obj) {
    if ( !obj.readable ) {
        return "There's nothing written on the #obj.name#.";
    }
    if ( obj.id == "book" ) {
        var ceremony = handleExorciseReading();
        if ( ceremony.len() ) {
            return ceremony;
        }
    }
    return obj.text;
}

// LLD-ROOM M-BEG's READ ,BOOK clause: with the ghosts already cowed by the
// hot bell and the candles lit, reading the book completes the ceremony —
// banishes the ghosts and sets lldFlag, unblocking the gate. Returns ""
// (falls through to the book's ordinary text) unless all the conditions
// for the climactic line are met.
function handleExorciseReading() {
    if ( gameState.currentRoom != "entrance_to_hades" || gameState.flags.lldFlag ) {
        return "";
    }
    if ( objects.hot_bell.location != "entrance_to_hades" && objects.hot_bell.location != "player" ) {
        return "";
    }
    if ( objects.candles.location != "player" || !objects.candles.on ) {
        return "";
    }

    gameState.flags.lldFlag = true;
    objects.ghosts.location = "";

    return "Each word of the prayer reverberates through the hall in a deafening
confusion. As the last word fades, a voice, loud and commanding,
speaks: ""Begone, fiends!"" A heart-stopping scream fills the cavern,
and the spirits, sensing a greater power, flee through the walls.";
}

function carriedIds() {
    return objects.keyArray().filter( (id) => objects[ id ].location == "player" );
}

// V-EAT, shared by both the EAT and DRINK verbs exactly as ZIL does it
// (V-DRINK is literally <V-EAT>): a FOODBIT item (lunch/garlic) just needs
// to be held — DRINK on one is rebuffed ("How can you drink that?") rather
// than eaten. A DRINKBIT item (water) needs an accessible source instead:
// global water (streams/river glimpsed from the room) drinks freely, but
// the bottled water needs its container actually held and open first.
// Anything else gets the same generic brush-off regardless of verb. A
// successful eat/drink consumes the item (REMOVE-CAREFULLY) — it doesn't
// just sit there to be eaten/drunk again.
function handleEatOrDrink(obj, verb) {
    if ( obj.food ) {
        if ( obj.location != "player" ) {
            var holder = objects[ obj.location ];
            if ( !isStruct( holder ) || holder.location != "player" ) {
                return "You're not holding that.";
            }
        }
        if ( verb == "drink" ) {
            return "How can you drink that?";
        }
        obj.location = "";
        return "Thank you very much. It really hit the spot.";
    }
    if ( obj.drinkable ) {
        if ( obj.id != "global_water" ) {
            var container = objects[ obj.location ];
            if ( !isStruct( container ) ) {
                return "There isn't any water here.";
            }
            if ( container.location != "player" ) {
                return "You have to be holding the #container.name# first.";
            }
            if ( !container.open ) {
                return "You'll have to open the #container.name# first.";
            }
        }
        obj.location = "";
        return "Thank you very much. I was rather thirsty (from all this talking, probably).";
    }
    return "I don't think that the #obj.name# would agree with you.";
}

function handleDrink(obj) {
    return handleEatOrDrink( obj, "drink" );
}

function handleEat(obj) {
    return handleEatOrDrink( obj, "eat" );
}

// ZIL distinguishes CLIMB-UP/CLIMB-DOWN by grammar; this collapses both to
// "up" (the common case — tree, dome rope, cliffs) and just reuses the
// normal exit machinery, so any requiresOpen/requiresFlag on that exit
// still applies.
function handleClimb(obj) {
    if ( !obj.climbable ) {
        return "You can't climb that.";
    }
    return handleGo( "up" );
}

// SCEPTRE-FUNCTION: waving the sceptre at the falls or the end of the
// rainbow toggles rainbowFlag (making the rainbow solid/crossable, and the
// pot of gold visible at the rainbow's end); waving it while standing on
// the rainbow itself drops it out from under you.
function handleWave(obj) {
    if ( obj.id != "sceptre" ) {
        return "Nothing happens.";
    }
    if ( gameState.currentRoom == "aragain_falls" || gameState.currentRoom == "end_of_rainbow" ) {
        if ( !gameState.flags.rainbowFlag ) {
            gameState.flags.rainbowFlag = true;
            var message = "Suddenly, the rainbow appears to become solid and, I venture," &
                NEWLINE & "walkable (I think the giveaway was the stairs and bannister).";
            if ( gameState.currentRoom == "end_of_rainbow" && objects.pot_of_gold.location == "end_of_rainbow" ) {
                objects.pot_of_gold.hidden = false;
                message &= NEWLINE & "A shimmering pot of gold appears at the end of the rainbow.";
            }
            return message;
        }
        gameState.flags.rainbowFlag = false;
        return "The rainbow seems to have become somewhat run-of-the-mill.";
    }
    if ( gameState.currentRoom == "on_rainbow" ) {
        gameState.flags.rainbowFlag = false;
        return endGame(
            "The structural integrity of the rainbow is severely compromised," &
            NEWLINE & "leaving you hanging in midair, supported only by water vapor. Bye."
        );
    }
    return "A dazzling display of color briefly emanates from the sceptre.";
}

// BELL-F/LLD-ROOM M-BEG: ringing the bell at the Hades gate while the
// ghosts still bar the way scares them into a paralyzed silence and
// scorches the bell red hot (HOT-BELL). Any lit candles you're holding
// drop and go out in the confusion, same as the ZIL text. Ringing it
// anywhere else, or after the ghosts are already banished, does nothing.
function handleRing(obj) {
    if ( obj.id != "bell" ) {
        return "Nothing happens.";
    }
    if ( gameState.currentRoom != "entrance_to_hades" || gameState.flags.lldFlag ) {
        return "Nothing happens.";
    }

    obj.location = "";
    objects.hot_bell.location = gameState.currentRoom;

    var lines = [ "The bell suddenly becomes red hot and falls to the ground. The
wraiths, as if paralyzed, stop their jeering and slowly turn to face
you. On their ashen faces, the expression of a long-forgotten terror
takes shape." ];

    if ( objects.candles.location == "player" ) {
        objects.candles.on = false;
        objects.candles.location = gameState.currentRoom;
        lines.append( "In your confusion, the candles drop to the ground (and they are out)." );
    }

    return lines.toList( NEWLINE );
}

// FOREST-ROOM?: forest_1/2/3, the path, and up the tree.
FOREST_ROOMS = [ "forest_1", "forest_2", "forest_3", "path", "up_a_tree" ];

// CANARY-OBJECT's WIND handling: the intact canary, wound in a forest room
// for the first time, triggers the songbird/bauble payoff (SING-SONG);
// elsewhere it just chirps. The broken canary only grinds unpleasantly.
function handleWind(obj) {
    if ( obj.id == "broken_canary" ) {
        return "There is an unpleasant grinding noise from inside the canary.";
    }
    if ( obj.id != "canary" ) {
        return "Nothing happens.";
    }
    if ( !gameState.flags.songSung && FOREST_ROOMS.contains( gameState.currentRoom ) ) {
        gameState.flags.songSung = true;
        objects.bauble.location = gameState.currentRoom == "up_a_tree" ? "path" : gameState.currentRoom;
        objects.bauble.hidden = false;
        return "The canary chirps, slightly off-key, an aria from a forgotten opera.
From out of the greenery flies a lovely songbird. It perches on a
limb just over your head and opens its beak to sing. As it does so
a beautiful brass bauble drops from its mouth, bounces off the top of
your head, and lands glimmering in the grass. As the canary winds
down, the songbird flies away.";
    }
    return "The canary chirps blithely, if somewhat tinnily, for a short time.";
}

// MIRROR-MIRROR: rubbing either mirror swaps the two mirror rooms' contents
// (other than the mirrors themselves, which are fixed scenery) and teleports
// the player to the other room — a "rumble from deep within the earth"
// rather than a normal exit. The original also short-circuits to a generic
// tingling message if rubbing it with something other than your bare hands;
// this engine's "rub X" grammar has no indirect object yet, so that branch
// doesn't apply.
function handleRub(obj, indirect) {
    if ( ![ "mirror_1", "mirror_2" ].contains( obj.id ) ) {
        return "Rubbing the #obj.name# doesn't seem to accomplish anything.";
    }
    if ( gameState.flags.mirrorBroken ) {
        return "The mirror is broken into many pieces.";
    }
    // MIRROR-MIRROR's PRSI check: rubbing the mirror with something (this
    // engine has no bare-hands object, so any indirect object qualifies)
    // just tingles instead of triggering the teleport.
    if ( isStruct( indirect ) ) {
        return "You feel a faint tingling transmitted through the #indirect.name#.";
    }

    var otherRoomId = obj.id == "mirror_1" ? "mirror_room_2" : "mirror_room_1";
    var thisRoomId = gameState.currentRoom;

    var movingOut = objects.keyArray().filter(
        (id) => objects[ id ].location == thisRoomId && !objects[ id ].scenery
    );
    var movingIn = objects.keyArray().filter(
        (id) => objects[ id ].location == otherRoomId && !objects[ id ].scenery
    );
    for ( var id in movingOut ) {
        objects[ id ].location = otherRoomId;
    }
    for ( var id in movingIn ) {
        objects[ id ].location = thisRoomId;
    }

    enterRoom( otherRoomId );
    return "There is a rumble from deep within the earth and the room shakes.";
}

function handleSearch(obj) {
    return handleExamine( obj );
}

// Rooms where the coal-gas odor (SMELLY-ROOM/GAS-ROOM's "GAS"/"ODOR"
// PSEUDO-object, GAS-PSEUDO) is the ambient smell — this engine has no
// pseudo-object vocabulary, so it's only reachable via bare "smell" here
// rather than "smell gas"/"smell odor" too.
GAS_SMELL_ROOMS = [ "smelly_room", "gas_room" ];

// V-SMELL: generic case just names the object back at you (SANDWICH-BAG-FCN
// and GAS-PSEUDO are the two object/room-specific overrides this engine
// implements). ZIL has no bare "SMELL" syntax at all (object required) —
// bare "smell" here falls back to the room's ambient odor, if any, else the
// generic "nothing unusual."
function handleSmell(obj) {
    if ( !isStruct( obj ) ) {
        if ( GAS_SMELL_ROOMS.contains( gameState.currentRoom ) ) {
            return "It smells like coal gas in here.";
        }
        return "You smell nothing unusual.";
    }
    if ( obj.id == "sandwich_bag" && objects.lunch.location == "sandwich_bag" ) {
        return "It smells of hot peppers.";
    }
    return "It smells like a #obj.name#.";
}

// V-LISTEN only exists as "LISTEN TO/FOR OBJECT" in ZIL (no bare syntax),
// and almost every interesting response is per-actor (TROLL-FCN/
// CYCLOPS-ROOM-FCN/THIEF-FCN) or per-room (FOREST-F). Bare "listen" here is
// this engine's own convenience fallback to ambient forest flavor, else the
// generic "nothing unusual."
function handleListenVerb(obj) {
    if ( isStruct( obj ) ) {
        switch ( obj.id ) {
            case "troll":
                return "Every so often the troll says something, probably uncomplimentary, in
his guttural tongue.";
            case "cyclops":
                return "You can hear his stomach rumbling.";
            case "thief":
                return "The thief says nothing, as you have not been formally introduced.";
            case "songbird":
                return "You can't hear the songbird now.";
        }
        return "The #obj.name# makes no sound.";
    }
    if ( FOREST_ROOMS.contains( gameState.currentRoom ) ) {
        return "The pines and the hemlocks seem to be murmuring.";
    }
    return "You hear nothing unusual.";
}

// SOUTH-TEMPLE-FCN's COFFIN-CURE check: in the real game this is set
// automatically on entering the Altar without the coffin, but per this
// task it's wired to the PRAY verb instead — praying at the Altar lifts
// the curse as long as you aren't lugging the coffin around with you.
// DEAD-FUNCTION's PRAY override: un-death only works at the Altar.
function handleGhostPray() {
    if ( gameState.currentRoom != "south_temple" ) {
        return "Your prayers are not heard.";
    }
    gameState.flags.ghost = false;
    // The death-time TROLL-FLAG override only stands if the troll was
    // actually defeated; if he's still standing guard (strength > 0),
    // un-death restores the danger (and the blocked passages) rather than
    // leaving them open.
    if ( objects.troll.location == "troll_room" && objects.troll.strength > 0 ) {
        gameState.flags.trollFlag = false;
    }
    return "From the distance the sound of a lone trumpet is heard. The room
becomes very bright and you feel disembodied. In a moment, the
brightness fades and you find yourself rising as if from a long
sleep, deep in the woods. In the distance you can faintly hear a
songbird and the sounds of the forest." & NEWLINE & NEWLINE & enterRoom( "forest_1" );
}

// DEAD-FUNCTION's LOOK override: room looks "strange and unearthly," plus a
// note about indistinct objects if any are actually here, plus a note that
// the ghost can see fine even where the room itself has no natural light.
function handleGhostLook() {
    var room = rooms[ gameState.currentRoom ];
    var hasObjects = false;
    for ( var id in objects ) {
        if ( objects[ id ].location == gameState.currentRoom && !objects[ id ].hidden ) {
            hasObjects = true;
            break;
        }
    }
    var msg = "The room looks strange and unearthly" & ( hasObjects ? " and objects appear indistinct." : "." );
    if ( !( room.keyExists( "lit" ) && room.lit ) ) {
        msg &= NEWLINE & "Although there is no light, the room seems dimly illuminated.";
    }
    return msg;
}

// DEAD-FUNCTION: while a ghost, almost every verb is intercepted by the
// player's own action override before its normal handler ever runs — the
// physical world is simply out of reach. WALK/SAVE fall through untouched
// (movement's own ghost special-case lives in handleGo(); SAVE works as
// normal). Anything not listed here gets the generic "can't even do that."
function handleGhostVerb(verb) {
    switch ( verb ) {
        case "attack":
            return "All such attacks are vain in your condition.";
        case "open": case "close": case "drink": case "eat": case "inflate":
        case "turn": case "burn": case "tie": case "rub":
            return "Even such an action is beyond your capabilities.";
        case "turn_on": case "turn_off":
            return "You need no light to guide you.";
        case "score":
            return "You're dead! How can you think of your score?";
        case "take":
            return "Your hand passes through its object.";
        case "drop": case "throw": case "inventory":
            return "You have no possessions.";
        case "diagnose":
            return "You are dead.";
        case "look":
            return handleGhostLook();
        case "pray":
            return handleGhostPray();
        case "save":
            return "";
    }
    return "You can't even do that.";
}

function handlePray() {
    if ( gameState.flags.ghost ) {
        return handleGhostPray();
    }
    if ( gameState.currentRoom == "south_temple" ) {
        if ( objects.coffin.location == "player" ) {
            return "Your prayers are not heard while you bear the weight of the coffin.";
        }
        gameState.flags.coffinCure = true;
        return "Your prayers are heard. The curse upon the coffin is lifted, and you
sense it is now safe to carry it below.";
    }
    return "Nothing happens.";
}

// V-DIAGNOSE, verbatim wording for wound severity, time-to-heal,
// survivability, and the deaths-so-far line.
function handleDiagnose() {
    var wd = -gameState.playerStrengthAdjustment;
    var msg = "";
    if ( wd == 0 ) {
        msg = "You are in perfect health.";
    } else {
        msg = "You have ";
        if ( wd == 1 ) {
            msg &= "a light wound,";
        } else if ( wd == 2 ) {
            msg &= "a serious wound,";
        } else if ( wd == 3 ) {
            msg &= "several wounds,";
        } else {
            msg &= "serious wounds,";
        }
        // CURE_WAIT*(WD-1) full heal cycles still to come, plus however
        // many turns are left on the cycle already in progress.
        var movesToCure = CURE_WAIT * ( wd - 1 ) + gameState.cureTimer;
        msg &= " which will be cured after #movesToCure# moves.";
    }
    // RS, verbatim from V-DIAGNOSE: unadjusted base strength plus wound
    // count (not the wound-adjusted strength fightStrength(true) gives).
    var rs = fightStrength( false ) + wd;
    msg &= NEWLINE & "You can ";
    if ( rs <= 0 ) {
        msg &= "expect death soon";
    } else if ( rs == 1 ) {
        msg &= "be killed by one more light wound";
    } else if ( rs == 2 ) {
        msg &= "be killed by a serious wound";
    } else if ( rs == 3 ) {
        msg &= "survive one serious wound";
    } else {
        msg &= "survive several wounds";
    }
    msg &= ".";
    if ( gameState.deaths > 0 ) {
        msg &= NEWLINE & "You have been killed " & ( gameState.deaths == 1 ? "once" : "twice" ) & ".";
    }
    return msg;
}

// V-SCORE's rank table, verbatim thresholds (out of the original 350).
function scoreRank(score) {
    if ( score == 350 ) {
        return "Master Adventurer";
    } else if ( score > 330 ) {
        return "Wizard";
    } else if ( score > 300 ) {
        return "Master";
    } else if ( score > 200 ) {
        return "Adventurer";
    } else if ( score > 100 ) {
        return "Junior Adventurer";
    } else if ( score > 50 ) {
        return "Novice Adventurer";
    } else if ( score > 25 ) {
        return "Amateur Adventurer";
    }
    return "Beginner";
}

function handleScore() {
    var points = handleScoreValue();
    return "Your score is #points# (total of 350 points), in #gameState.turns# move(s)." &
        NEWLINE & "This gives you the rank of #scoreRank( points )#.";
}

SAVE_FILE = "zork.save";

// Serialize current game state and all mutable object fields to SAVE_FILE.
function handleSave() {
    var objectState = {};
    for ( var id in objects ) {
        var obj = objects[ id ];
        objectState[ id ] = {
            "location"  : obj.location,
            "on"        : obj.on,
            "open"      : obj.open,
            "hidden"    : obj.hidden,
            "fuel"      : obj.fuel,
            "burnedOut" : obj.burnedOut,
            "locked"    : obj.locked
        };
    }
    fileWrite( SAVE_FILE, jsonSerialize( { "gameState" : gameState, "objectState" : objectState } ) );
    return "Saved.";
}

// Restore game state from SAVE_FILE if it exists. Called once at startup
// before the first prompt.
function loadSave() {
    if ( !fileExists( SAVE_FILE ) ) {
        return;
    }
    try {
        var saved = jsonDeserialize( fileRead( SAVE_FILE ) );
        for ( var key in saved.gameState ) {
            gameState[ key ] = saved.gameState[ key ];
        }
        for ( var id in saved.objectState ) {
            var s = saved.objectState[ id ];
            objects[ id ].location  = s.location;
            objects[ id ].on        = s.on;
            objects[ id ].open      = s.open;
            objects[ id ].hidden    = s.hidden;
            objects[ id ].fuel      = s.fuel;
            objects[ id ].burnedOut = s.burnedOut;
            objects[ id ].locked    = s.locked;
        }
    } catch ( e ) {
        println( "(Save file could not be read; starting a new game.)" );
    }
}

// Sharp objects puncture the boat the moment they come aboard — mirrors
// RBOAT-FUNCTION's BOARD check (sceptre/knife/sword/rusty-knife/axe/stiletto
// in WINNER's inventory), simplified to "any weapon" rather than that fixed
// object list, since this engine already tracks WEAPONBIT generically.
function handleBoard(obj) {
    if ( ![ "inflatable_boat", "inflated_boat" ].contains( obj.id ) ) {
        return "You can't board that.";
    }
    if ( gameState.boardedVehicle.len() ) {
        return "You're already in the boat.";
    }
    if ( obj.id == "inflatable_boat" ) {
        return "You can't board that — it's not inflated.";
    }

    var sharpCarried = carriedIds().filter( (id) => objects[ id ].weapon );
    if ( sharpCarried.len() ) {
        objects.inflated_boat.location = "";
        objects.punctured_boat.location = gameState.currentRoom;
        return "Oops! Something sharp seems to have slipped and punctured the boat." & NEWLINE &
            "The boat deflates to the sounds of hissing, sputtering, and cursing.";
    }

    gameState.boardedVehicle = obj.id;
    return "You are now in the boat.";
}

// RIVER-LAUNCH: which river room (if any) launching from a given room drops
// you into. Rooms not listed here simply aren't valid places to launch from.
RIVER_LAUNCH = {
    "dam_base"           : "river_1",
    "white_cliffs_north" : "river_3",
    "white_cliffs_south" : "river_4",
    "shore"               : "river_5",
    "sandy_beach"         : "river_4"
};

// RIVER-NEXT: where the current carries the boat each turn while drifting.
RIVER_NEXT = {
    "river_1" : "river_2",
    "river_2" : "river_3",
    "river_3" : "river_4",
    "river_4" : "river_5"
};

// NONLANDBIT rooms: the river proper, where you can't be without the boat
// (VEHBIT check in WALK/M-BEG) and where the current keeps carrying you on
// (I-RIVER) until you land or run out of river.
RIVER_ROOMS = [ "river_1", "river_2", "river_3", "river_4", "river_5" ];

function handleLaunch() {
    if ( RIVER_ROOMS.contains( gameState.currentRoom ) ) {
        return "You are on the river, or have you forgotten?";
    }

    if ( !gameState.boardedVehicle.len() ) {
        return "You're not in the boat!";
    }

    if ( !RIVER_LAUNCH.keyExists( gameState.currentRoom ) ) {
        return "You can't launch it here.";
    }

    // ZIL queues I-RIVER to start running on a later turn (ENABLE <QUEUE
    // I-RIVER ...> at the end of LAUNCH), so the room you launch into this
    // turn shouldn't also drift downstream this same turn.
    gameState.skipRiverDriftThisTurn = true;
    var boatId = gameState.boardedVehicle;
    var description = enterRoom( RIVER_LAUNCH[ gameState.currentRoom ] );
    objects[ boatId ].location = gameState.currentRoom;
    return "You launch the boat onto the river." & NEWLINE & description;
}

// LAND: ZIL's "go ashore" verb for the boat, and also a per-room exit key
// used when only one landing direction makes sense (e.g. RIVER-1's west
// bank). Disembarking moves the boat (not just the player) into the new
// room, mirroring RBOAT-FUNCTION/THIS-IS-IT.
function handleLand() {
    if ( !gameState.boardedVehicle.len() ) {
        return "You're not in a boat!";
    }

    var room = rooms[ gameState.currentRoom ];
    if ( !room.exits.keyExists( "land" ) ) {
        return "You can't land here.";
    }

    var exit = room.exits.land;
    if ( !isSimpleValue( exit ) ) {
        return exit.blocked;
    }

    var boatId = gameState.boardedVehicle;
    gameState.boardedVehicle = "";
    var description = enterRoom( exit );
    objects[ boatId ].location = gameState.currentRoom;
    return description;
}

// I-RIVER: each turn spent boarded on the river without landing, the
// current carries you one room further downstream (no speed/queue timing
// modeled, just one room per turn). Drifting past river_5 with nowhere
// further to go is the waterfall death from RBOAT-FUNCTION's I-RIVER ELSE
// clause. Returns an extra line to append after the turn's own output, or
// "" if the player isn't drifting this turn.
function tickRiver() {
    if ( gameState.skipRiverDriftThisTurn ) {
        gameState.skipRiverDriftThisTurn = false;
        return "";
    }

    if ( !gameState.boardedVehicle.len() || !RIVER_ROOMS.contains( gameState.currentRoom ) ) {
        return "";
    }

    if ( !RIVER_NEXT.keyExists( gameState.currentRoom ) ) {
        return endGame(
"Unfortunately, the magic boat doesn't provide protection from
the rocks and boulders one meets at the bottom of waterfalls.
Including this one."
        );
    }

    var nextRoom = RIVER_NEXT[ gameState.currentRoom ];
    var boatId = gameState.boardedVehicle;
    var description = enterRoom( nextRoom );
    objects[ boatId ].location = gameState.currentRoom;
    return "The flow of the river carries you downstream." & NEWLINE & NEWLINE & description;
}

// Generic scenery interaction; the rug is the one well-defined source
// mechanic worth wiring for real (RUG-FCN's MOVE/RAISE/LIFT handling).
function handlePush(obj) {
    if ( obj.id == "rug" ) {
        if ( gameState.flags.rugMoved ) {
            return "The rug has already been moved.";
        }
        gameState.flags.rugMoved = true;
        objects.trap_door.hidden = false;
        return "With great effort, you move the rug to one side of the room, revealing a closed trap door.";
    }
    // BUTTON-F: the blue button bursts a pipe in the maintenance room,
    // revealing the leak and starting the water-level flooding timer
    // (I-MAINT-ROOM, tickMaintRoom()). <0? WATER-LEVEL> is the real gate —
    // a one-shot: it's only ever 0 before the first push, never again
    // afterward (1+ while leaking, -1 once patched), so pushing it again at
    // any point afterward — even post-fix — reports jammed, same as ZIL.
    if ( obj.id == "blue_button" ) {
        if ( gameState.waterLevel != 0 ) {
            return "The blue button appears to be jammed.";
        }
        objects.leak.hidden = false;
        gameState.waterLevel = 1;
        return "There is a rumbling sound and a stream of water appears to burst" &
            NEWLINE & "from the east wall of the room (apparently, a leak has occurred in a" &
            NEWLINE & "pipe).";
    }
    if ( obj.id == "red_button" ) {
        return "The lights within the room come on.";
    }
    // BUTTON-F: yellow/brown set/clear GATE-FLAG, which is what lets the
    // bolt turn at all (handleTurn) — the dam control panel's bubble glows
    // while it's set.
    if ( obj.id == "yellow_button" ) {
        gameState.flags.gateFlag = true;
        return "Click.";
    }
    if ( obj.id == "brown_button" ) {
        gameState.flags.gateFlag = false;
        return "Click.";
    }
    return "Pushing the #obj.name# doesn't seem to accomplish anything.";
}

// BASKET-F: the dumbwaiter's chain-pull. RAISE/LOWER swap which end of
// the chain the basket (lowered_basket/raised_basket — same physical
// object, different room/state, as in ZIL) sits at, between the Shaft
// Room (top) and the Drafty Room (bottom). CAGE-TOP tracks which end
// currently holds it.
function handleRaise(obj) {
    if ( obj.id == "rug" ) {
        return "The rug is too heavy to lift" & ( gameState.flags.rugMoved ?
            "." :
            ", but in trying to take it you have noticed an irregularity beneath it." );
    }
    if ( [ "lowered_basket", "raised_basket" ].contains( obj.id ) ) {
        if ( gameState.flags.cageTop ) {
            return "The basket is already at the top of the shaft.";
        }
        objects.raised_basket.location = "shaft_room";
        objects.lowered_basket.location = "lower_shaft";
        gameState.flags.cageTop = true;
        return "The basket is raised to the top of the shaft.";
    }
    return "You can't raise that.";
}

function handleLower(obj) {
    if ( [ "lowered_basket", "raised_basket" ].contains( obj.id ) ) {
        if ( !gameState.flags.cageTop ) {
            return "The basket is already at the bottom of the shaft.";
        }
        objects.raised_basket.location = "lower_shaft";
        objects.lowered_basket.location = "shaft_room";
        gameState.flags.cageTop = false;
        return "The basket is lowered to the bottom of the shaft.";
    }
    return "You can't lower that.";
}

// V-KICK: pure HACK-HACK flavor stub in ZIL, no object-specific override.
function handleKick(obj) {
    return "Kicking the #obj.name# doesn't seem to help.";
}

// V-CUT: no WEAPONBIT/tool modeling for a "with" object in this port, so this
// always falls to ZIL's generic "strange concept" line rather than the
// weapon-specific branches in V-CUT.
function handleCut(obj) {
    return "Strange concept, cutting the #obj.name#....";
}

// V-LOOK-UNDER: ZIL's generic stub. (1actions.zil does override this for a
// few specific objects — trap-door rug, leaf pile, rainbow — but those route
// through each room/object's own F-routine, which this engine has no
// equivalent hook for; out of scope here.)
function handleLookUnder(obj) {
    return "There is nothing but dust there.";
}

// V-FOLLOW: pure flavor stub in ZIL ("You're nuts!"). (1actions.zil's
// SONGBIRD-F adds a FOLLOW override for the songbird, but that's a
// room/object F-routine hook this engine doesn't have; out of scope here.)
function handleFollow(obj) {
    return "You're nuts!";
}

// V-ALARM/WAKE: ZIL's stub checks ACTORBIT and sleep state (STRENGTH < 0) to
// pick between "rudely awakened", "wide awake", or "isn't sleeping" — none of
// that state exists in this port, so this always reports the generic
// non-actor/non-sleeping case.
function handleWake(obj) {
    return "The #obj.name# isn't sleeping.";
}

// V-REPLY/ANSWER: pure flavor stub in ZIL, no object-specific override.
function handleAnswer(obj) {
    return "It is hardly likely that the #obj.name# is interested.";
}

// MSWITCH-FUNCTION: turning on the coal mine's machine (clothes-dryer
// shaped contraption with the START switch). Mirrors "turn on machine"/
// "turn on switch" to MSWITCH-FUNCTION's TURN-WITH-SCREWDRIVER case,
// simplified to not require the screwdriver (the engine doesn't support
// an indirect object on turn_on/turn_off). Coal in the machine becomes a
// diamond; anything else left inside is destroyed into worthless gunk.
function runCoalMachine() {
    if ( objects.machine.open ) {
        return "The machine doesn't seem to want to do anything.";
    }
    var contents = objects.keyArray().filter( (id) => objects[ id ].location == "machine" );
    if ( contents.contains( "coal" ) ) {
        objects.coal.location = "";
        objects.diamond.location = "machine";
        objects.diamond.hidden = false;
    } else if ( contents.len() ) {
        for ( var id in contents ) {
            objects[ id ].location = "";
        }
        objects.gunk.location = "machine";
        objects.gunk.hidden = false;
    }
    return "The machine comes to life (figuratively) with a dazzling display of
colored lights and bizarre noises. After a few moments, the
excitement abates.";
}

function handleTurnOn(obj) {
    if ( obj.id == "machine" || obj.id == "machine_switch" ) {
        return runCoalMachine();
    }
    if ( obj.id == "match" ) {
        return handleStrikeMatch();
    }
    if ( !obj.light ) {
        return "You can't turn that on.";
    }
    if ( obj.burnedOut ) {
        return "A burned-out #obj.name# won't light.";
    }
    if ( obj.on ) {
        return "It's already on.";
    }
    obj.on = true;
    return "The #obj.name# is now on.";
}

function handleExtinguish(obj) {
    if ( obj.id == "match" ) {
        if ( !obj.on ) {
            return "It's already out.";
        }
        obj.on = false;
        obj.fuel = -1;
        return "The match is out.";
    }
    if ( !obj.light ) {
        return "You can't turn that off.";
    }
    if ( obj.burnedOut ) {
        return "The #obj.name# has already burned out.";
    }
    if ( !obj.on ) {
        return "It's already off.";
    }
    obj.on = false;
    return "The #obj.name# is now off.";
}

// MATCH-FUNCTION: strikes a fresh match off the matchbook. Six per game
// (gameState.matchCount); each burns for exactly 2 turns (tickMatch) unless
// put out early, and goes out instantly in a drafty room.
function handleStrikeMatch() {
    if ( gameState.matchCount <= 0 ) {
        return "I'm afraid that you have run out of matches.";
    }
    gameState.matchCount -= 1;
    if ( [ "lower_shaft", "timber_room" ].contains( gameState.currentRoom ) ) {
        return "This room is drafty, and the match goes out instantly.";
    }
    objects.match.on = true;
    objects.match.fuel = 2;
    return "One of the matches starts to burn.";
}

// "light X" turns on a light source, or sets fire to a burnable one —
// mirrors how ZIL's LAMP-ON/BURN verbs overlap on the word "light".
function handleLight(obj) {
    if ( obj.id == "candles" ) {
        var result = handleTurnOn( obj );
        if ( obj.on ) {
            var ceremonyNote = checkHadesCeremonyProgress();
            if ( ceremonyNote.len() ) {
                result &= NEWLINE & ceremonyNote;
            }
        }
        return result;
    }
    if ( obj.id == "match" ) {
        return handleStrikeMatch();
    }
    if ( obj.light ) {
        return handleTurnOn( obj );
    }
    if ( obj.burnable ) {
        return handleBurn( obj, "" );
    }
    return "You can't light that.";
}

// I-XB/I-XC simplified: lighting the candles after the bell has scared the
// ghosts off (hot_bell on the ground at the Hades gate) is the second step
// of the exorcism — "the earth trembles" beat from LLD-ROOM's M-END. No
// turn-based forgiveness window is modeled (this engine has no demon
// queue); the only requirement is having rung the bell first.
function checkHadesCeremonyProgress() {
    if ( gameState.currentRoom != "entrance_to_hades" || gameState.flags.lldFlag ) {
        return "";
    }
    if ( objects.hot_bell.location != "entrance_to_hades" && objects.hot_bell.location != "player" ) {
        return "";
    }
    return "The flames flicker wildly and appear to dance. The earth beneath
your feet trembles, and your legs nearly buckle beneath you.
The spirits cower at your unearthly power.";
}

function findLitLightSource() {
    var lit = carriedIds().filter( (id) => objects[ id ].light && objects[ id ].on );
    return lit.len() ? objects[ lit[ 1 ] ] : "";
}

function handleBurn(obj, indirect) {
    if ( !obj.burnable ) {
        return "You can't burn that.";
    }
    var source = isStruct( indirect ) ? indirect : findLitLightSource();
    if ( !isStruct( source ) ) {
        return "You have nothing to light it with.";
    }
    if ( !source.light || !source.on ) {
        return "The #source.name# isn't lit.";
    }
    var objLocation = obj.location;
    obj.location = "";
    // Putty melts down to a residue (small piece of vitreous slag) rather
    // than just burning away like other burnables.
    if ( obj.id == "putty" ) {
        objects.gunk.location = objLocation;
        objects.gunk.hidden = false;
        return "The viscous material melts away, leaving behind a small piece of vitreous slag.";
    }
    return "The #obj.name# catches fire and burns up.";
}

// SAND-FUNCTION: digging the sand in the Sandy Cave with the shovel. The
// scarab surfaces on the 4th consecutive dig; a 5th without taking it
// first collapses the hole on top of the player (BEACH-DIG counter,
// reset on death or once the scarab is found).
BDIGS = [
    "You seem to be digging a hole here.",
    "The hole is getting deeper, but that's about it.",
    "You are surrounded by a wall of sand on all sides."
];

function handleDig(obj, indirect) {
    if ( obj.id != "sand" ) {
        return "The ground is too hard to dig here.";
    }
    if ( !isStruct( indirect ) || indirect.id != "shovel" ) {
        return "Digging without a shovel would be slow and tiresome.";
    }
    if ( indirect.location != "player" ) {
        return "You don't have the shovel.";
    }

    gameState.beachDig += 1;

    if ( gameState.beachDig > 3 ) {
        gameState.beachDig = -1;
        return endGame( "The hole collapses, smothering you." );
    }
    if ( gameState.beachDig == 3 ) {
        if ( objects.scarab.hidden ) {
            objects.scarab.hidden = false;
            return "You can see a scarab here in the sand.";
        }
        return BDIGS[ 1 ];
    }
    return BDIGS[ gameState.beachDig + 1 ];
}

// BOLT-F: turning the dam's bolt with the wrench needs GATE-FLAG set first
// (yellow button, handlePush) — the bubble glowing is what tells you that.
// Once gated, it toggles GATES-OPEN (not lowTide directly); the reservoir
// itself only actually drains/refills 8 turns later, via tickDam().
function handleTurn(obj, indirect) {
    if ( obj.id == "bolt" ) {
        if ( !isStruct( indirect ) ) {
            return "You'll need the wrench to turn the bolt.";
        }
        if ( indirect.id != "wrench" ) {
            return "The bolt won't turn using the #indirect.name#.";
        }
        if ( indirect.location != "player" ) {
            return "You don't have the wrench.";
        }
        if ( !gameState.flags.gateFlag ) {
            return "The bolt won't turn with your best effort.";
        }
        if ( gameState.flags.gatesOpen ) {
            gameState.flags.gatesOpen = false;
            gameState.gatesTransitionTurns = 8;
            return "The sluice gates close and water starts to collect behind the dam.";
        }
        gameState.flags.gatesOpen = true;
        gameState.gatesTransitionTurns = 8;
        return "The sluice gates open and water pours through the dam.";
    }
    return "Turning the #obj.name# doesn't seem to accomplish anything.";
}

// ---------------------------------------------------------------------
// Combat (ported from DO-FIGHT/VILLAIN-BLOW/HERO-BLOW/VILLAIN-STRENGTH in
// 1actions.zil). Faithful to the real strength tables, weapon-advantage
// rule, and per-villain message tables. Simplified: no demon/interrupt
// queue, so each "attack" command resolves one full exchange (your blow,
// then the villain's blow back) synchronously instead of being spread
// across the real game's per-turn demon ticks; the troll's 33% chance to
// hold off before his first counter-attack, the brief extra "sitting duck"
// follow-up swing right after a foe wakes from unconsciousness, and the
// player's slow natural healing between fights (I-CURE) aren't modeled.
// ---------------------------------------------------------------------

BLOW_MISSED         = 1;
BLOW_UNCONSCIOUS    = 2;
BLOW_KILLED         = 3;
BLOW_LIGHT_WOUND    = 4;
BLOW_SERIOUS_WOUND  = 5;
BLOW_STAGGER        = 6;
BLOW_LOSE_WEAPON    = 7;

DEF1  = [ 1,1,1,1, 6,6, 2,2, 3,3,3,3,3 ];
DEF2A = [ 1,1,1,1,1, 6,6, 4,4, 2 ];
DEF2B = [ 1,1,1, 6,6, 4,4,4, 2, 3,3,3 ];
DEF3A = [ 1,1,1,1,1, 6,6, 4,4, 5,5 ];
DEF3B = [ 1,1,1, 6,6, 4,4,4, 5,5,5 ];
DEF3C = [ 1, 6,6, 4,4,4,4, 5,5,5 ];

// DEF1-RES/DEF2-RES/DEF3-RES: ZIL selects a 9-entry "window" into one of
// these base tables, sliding the window toward worse outcomes as the
// attacker's relative advantage increases (REST by 2, then by 4).
DEF1_RES = [ DEF1, DEF1.slice( 3 ), DEF1.slice( 5 ) ];
DEF2_RES = [ DEF2A, DEF2B, DEF2B.slice( 3 ), DEF2B.slice( 5 ) ];
DEF3_RES = [ DEF3A, DEF3A.slice( 3 ), DEF3B, DEF3B.slice( 3 ), DEF3C ];

STRENGTH_MIN = 2;
STRENGTH_MAX = 7;

CURE_WAIT = 30; // CURE-WAIT: turns between each 1-point I-CURE heal
DEATH_LIMIT = 2; // resurrections allowed before death becomes permanent
SCORE_PENALTY_PER_DEATH = 10; // SCORE-UPD -10, applied on every death
SCORE_MAX    = 350;

VILLAIN_CONFIG = {
    "troll"   : { "bestWeapon" : "sword", "bestWeaponAdvantage" : 1, "messages" : "TROLL_MELEE" },
    "thief"   : { "bestWeapon" : "rusty_knife", "bestWeaponAdvantage" : 1, "messages" : "THIEF_MELEE" },
    "cyclops" : { "bestWeapon" : "", "bestWeaponAdvantage" : 0, "messages" : "CYCLOPS_MELEE" }
};

// FIGHT-STRENGTH: grows with score (treasures found), 2..7, plus the
// player's current wound adjustment (negative while hurt).
function fightStrength(adjust = true) {
    var s = STRENGTH_MIN + int( handleScoreValue() / ( SCORE_MAX / ( STRENGTH_MAX - STRENGTH_MIN ) ) );
    return adjust ? s + gameState.playerStrengthAdjustment : s;
}

// OTVAL-FROB + BASE-SCORE: the trophy case's current TVALUE total (which
// drops if a treasure is removed) plus the one-time take points already
// banked in gameState.baseScore (which don't). Also what FIGHT-STRENGTH
// scales off of, same as real ZIL's ,SCORE.
function handleScoreValue() {
    var deposited = objects.keyArray().filter( (id) => objects[ id ].location == "trophy_case" );
    var points = gameState.baseScore;
    for ( var id in deposited ) {
        points += objects[ id ].treasureValue;
    }
    return points;
}

// VILLAIN-STRENGTH: the villain's current defense, reduced if the
// attacking weapon is their one weakness (sword vs. troll, knife vs. thief).
function villainStrength(villainId, weaponId) {
    var def = objects[ villainId ].strength;
    if ( def < 0 ) {
        return def;
    }
    var config = VILLAIN_CONFIG[ villainId ];
    if ( weaponId.len() && weaponId == config.bestWeapon ) {
        def -= config.bestWeaponAdvantage;
        if ( def < 1 ) {
            def = 1;
        }
    }
    return def;
}

// Picks a result table by defender strength, then a 1-of-9 random outcome
// from the appropriate "window" into it — exactly VILLAIN-BLOW/HERO-BLOW's
// branching (DEF==1 / DEF==2 / DEF>2 cases).
function resolveBlowOutcome(attIn, defIn) {
    var att = attIn;
    var table = "";
    if ( defIn == 1 ) {
        if ( att > 2 ) {
            att = 3;
        }
        table = DEF1_RES[ att ];
    } else if ( defIn == 2 ) {
        if ( att > 3 ) {
            att = 4;
        }
        table = DEF2_RES[ att ];
    } else {
        att -= defIn;
        if ( att < -1 ) {
            att = -2;
        } else if ( att > 1 ) {
            att = 2;
        }
        table = DEF3_RES[ att + 3 ];
    }
    var roll = randRange( 1, min( table.len(), 9 ) );
    var outcome = table[ roll ];
    // LOSE-WEAPON is a 25% override of a STAGGER roll, never its own table entry.
    if ( outcome == BLOW_STAGGER && randRange( 1, 100 ) <= 25 ) {
        return BLOW_LOSE_WEAPON;
    }
    return outcome;
}

function carriedWeapon() {
    var weapons = carriedIds().filter( (id) => objects[ id ].weapon );
    return weapons.len() ? objects[ weapons[ 1 ] ] : "";
}

// REMARK: substitutes the weapon name into a message template (villain
// name is baked directly into the source text in 1actions.zil, so only the
// weapon placeholder needs handling here).
function remark(template, weaponName) {
    return template.replaceNoCase( "{weapon}", weaponName.len() ? weaponName : "bare hands", "all" );
}

HERO_MELEE = {
    "1" : [ "Your {weapon} misses the {target} by an inch.",
            "A good slash, but it misses the {target} by a mile.",
            "You charge, but the {target} jumps nimbly aside.",
            "Clang! Crash! The {target} parries.",
            "A quick stroke, but the {target} is on guard.",
            "A good stroke, but it's too slow; the {target} dodges." ],
    "2" : [ "Your {weapon} crashes down, knocking the {target} into dreamland.",
            "The {target} is battered into unconsciousness.",
            "A furious exchange, and the {target} is knocked out!",
            "The haft of your {weapon} knocks out the {target}.",
            "The {target} is knocked out!" ],
    "3" : [ "It's curtains for the {target} as your {weapon} removes his head.",
            "The fatal blow strikes the {target} square in the heart: He dies.",
            "The {target} takes a fatal blow and slumps to the floor dead." ],
    "4" : [ "The {target} is struck on the arm; blood begins to trickle down.",
            "Your {weapon} pinks the {target} on the wrist, but it's not serious.",
            "Your stroke lands, but it was only the flat of the blade.",
            "The blow lands, making a shallow gash in the {target}'s arm!" ],
    "5" : [ "The {target} receives a deep gash in his side.",
            "A savage blow on the thigh! The {target} is stunned but can still fight!",
            "Slash! Your blow lands! That one hit an artery, it could be serious!",
            "Slash! Your stroke connects! This could be serious!" ],
    "6" : [ "The {target} is staggered, and drops to his knees.",
            "The {target} is momentarily disoriented and can't fight back.",
            "The force of your blow knocks the {target} back, stunned.",
            "The {target} is confused and can't fight back.",
            "The quickness of your thrust knocks the {target} back, stunned." ],
    "7" : [ "The {target}'s weapon is knocked to the floor, leaving him unarmed.",
            "The {target} is disarmed by a subtle feint past his guard." ]
};

TROLL_MELEE = {
    "1" : [ "The troll swings his axe, but it misses.",
            "The troll's axe barely misses your ear.",
            "The axe sweeps past as you jump aside.",
            "The axe crashes against the rock, throwing sparks!" ],
    "2" : [ "The flat of the troll's axe hits you delicately on the head, knocking you out." ],
    "3" : [ "The troll neatly removes your head.",
            "The troll's axe stroke cleaves you from the nave to the chops.",
            "The troll's axe removes your head." ],
    "4" : [ "The axe gets you right in the side. Ouch!",
            "The flat of the troll's axe skins across your forearm.",
            "The troll's swing almost knocks you over as you barely parry in time.",
            "The troll swings his axe, and it nicks your arm as you dodge." ],
    "5" : [ "The troll charges, and his axe slashes you on your {weapon} arm.",
            "An axe stroke makes a deep wound in your leg.",
            "The troll's axe swings down, gashing your shoulder." ],
    "6" : [ "The troll hits you with a glancing blow, and you are momentarily stunned.",
            "The troll swings; the blade turns on your armor but crashes broadside into your head.",
            "You stagger back under a hail of axe strokes.",
            "The troll's mighty blow drops you to your knees." ],
    "7" : [ "The axe hits your {weapon} and knocks it spinning.",
            "The troll swings, you parry, but the force of his blow knocks your {weapon} away.",
            "The axe knocks your {weapon} out of your hand. It falls to the floor." ]
};

THIEF_MELEE = {
    "1" : [ "The thief stabs nonchalantly with his stiletto and misses.",
            "You dodge as the thief comes in low.",
            "You parry a lightning thrust, and the thief salutes you with a grim nod.",
            "The thief tries to sneak past your guard, but you twist away." ],
    "2" : [ "Shifting in the midst of a thrust, the thief knocks you unconscious with the haft of his stiletto.",
            "The thief knocks you out." ],
    "3" : [ "Finishing you off, the thief inserts his blade into your heart.",
            "The thief comes in from the side, feints, and inserts the blade into your ribs.",
            "The thief bows formally, raises his stiletto, and with a wry grin, ends the battle and your life." ],
    "4" : [ "A quick thrust pinks your left arm, and blood starts to trickle down.",
            "The thief draws blood, raking his stiletto across your arm.",
            "The stiletto flashes faster than you can follow, and blood wells from your leg.",
            "The thief slowly approaches, strikes like a snake, and leaves you wounded." ],
    "5" : [ "The thief strikes like a snake! The resulting wound is serious.",
            "The thief stabs a deep cut in your upper arm.",
            "The stiletto touches your forehead, and the blood obscures your vision.",
            "The thief strikes at your wrist, and suddenly your grip is slippery with blood." ],
    "6" : [ "The butt of his stiletto cracks you on the skull, and you stagger back.",
            "The thief rams the haft of his blade into your stomach, leaving you out of breath.",
            "The thief attacks, and you fall back desperately." ],
    "7" : [ "A long, theatrical slash. You catch it on your {weapon}, but the thief twists his knife, and the {weapon} goes flying.",
            "The thief neatly flips your {weapon} out of your hands, and it drops to the floor.",
            "You parry a low thrust, and your {weapon} slips out of your hand." ]
};

CYCLOPS_MELEE = {
    "1" : [ "The Cyclops misses, but the backwash almost knocks you over.",
            "The Cyclops rushes you, but runs into the wall." ],
    "2" : [ "The Cyclops sends you crashing to the floor, unconscious." ],
    "3" : [ "The Cyclops breaks your neck with a massive smash." ],
    "4" : [ "A quick punch, but it was only a glancing blow.",
            "A glancing blow from the Cyclops' fist." ],
    "5" : [ "The monster smashes his huge fist into your chest, breaking several ribs.",
            "The Cyclops almost knocks the wind out of you with a quick punch." ],
    "6" : [ "The Cyclops lands a punch that knocks the wind out of you.",
            "Heedless of your weapons, the Cyclops tosses you against the rock wall of the room." ],
    "7" : [ "The Cyclops grabs your {weapon}, tastes it, and throws it to the ground in disgust.",
            "The monster grabs you on the wrist, squeezes, and you drop your {weapon} in pain." ]
};

MELEE_TABLES = { "TROLL_MELEE" : TROLL_MELEE, "THIEF_MELEE" : THIEF_MELEE, "CYCLOPS_MELEE" : CYCLOPS_MELEE };

// ABOVE-GROUND: where RANDOMIZE-OBJECTS dumps non-treasure carried items
// on death.
ABOVE_GROUND_ROOMS = [
    "west_of_house", "north_of_house", "east_of_house", "south_of_house",
    "forest_1", "forest_2", "forest_3", "path", "clearing", "grating_clearing",
    "canyon_view"
];

// RANDOMIZE-OBJECTS: on death, the lamp and coffin go home regardless, the
// sword loses its (latent) treasure value, and everything else still on the
// player scatters — treasures into a random dark room (so they can be found
// again), junk into a random above-ground room. Mirrors the ZIL routine's
// AUX pointer that keeps advancing through the room list across multiple
// scattered treasures in the same death, rather than re-rolling from the top
// each time.
function randomizeObjects() {
    if ( objects.brass_lantern.location == "player" ) {
        objects.brass_lantern.location = "living_room";
    }
    if ( objects.coffin.location == "player" ) {
        objects.coffin.location = "egypt_room";
    }
    objects.sword.treasureValue = 0;

    var darkRooms = [];
    for ( var id in rooms ) {
        if ( !( rooms[ id ].keyExists( "lit" ) && rooms[ id ].lit ) ) {
            darkRooms.append( id );
        }
    }

    var carried = [];
    for ( var id in objects ) {
        if ( objects[ id ].location == "player" ) {
            carried.append( id );
        }
    }

    var darkPtr = 0;
    for ( var id in carried ) {
        var obj = objects[ id ];
        if ( obj.treasureValue > 0 ) {
            var attempts = 0;
            var placed = false;
            while ( attempts < 200 && !placed ) {
                attempts += 1;
                darkPtr = ( darkPtr % darkRooms.len() ) + 1;
                if ( randRange( 1, 100 ) <= 50 ) {
                    obj.location = darkRooms[ darkPtr ];
                    placed = true;
                }
            }
            if ( !placed ) {
                obj.location = darkRooms[ randRange( 1, darkRooms.len() ) ];
            }
        } else {
            obj.location = ABOVE_GROUND_ROOMS[ randRange( 1, ABOVE_GROUND_ROOMS.len() ) ];
        }
    }
}

// KILL-INTERRUPTS: permanently silences the thief and the lantern/candle/
// match fuel timers after the first death (and snuffs any match currently
// burning) — checked via gameState.deaths in processCommand() rather than a
// disable flag per-demon.
function killInterrupts() {
    objects.match.on = false;
}

function endGame(message) {
    gameState.baseScore -= SCORE_PENALTY_PER_DEATH;

    if ( gameState.deaths >= DEATH_LIMIT ) {
        gameState.playerDead = true;
        return message & NEWLINE & NEWLINE & "    ****  You have died  ****" & NEWLINE & NEWLINE &
            "You clearly are a suicidal maniac. We don't allow psychotics in the cave, since
they may harm other adventurers. Your remains will be installed in the
Land of the Living Dead, where your fellow adventurers may gloat over them." &
            NEWLINE & NEWLINE & "The game is over.";
    }

    gameState.deaths += 1;
    var ghostLimbo = rooms.south_temple.keyExists( "touched" ) && rooms.south_temple.touched;
    randomizeObjects();
    killInterrupts();

    var resurrectText = "";
    if ( ghostLimbo ) {
        gameState.flags.ghost = true;
        gameState.flags.trollFlag = true;
        resurrectText =
            "As you take your last breath, you feel relieved of your burdens. The
feeling passes as you find yourself before the gates of Hell, where
the spirits jeer at you and deny you entry.  Your senses are
disturbed.  The objects in the dungeon appear indistinct, bleached of
color, even unreal." & NEWLINE & NEWLINE & enterRoom( "entrance_to_hades" );
    } else {
        gameState.playerStrengthAdjustment = 1 - fightStrength( false );
        gameState.cureTimer = gameState.playerStrengthAdjustment < 0 ? CURE_WAIT : 0;
        resurrectText =
            "Now, let's take a look here..." & NEWLINE &
            "Well, you probably deserve another chance.  I can't quite fix you up completely,
but you can't have everything." & NEWLINE & NEWLINE & enterRoom( "forest_1" );
    }

    return message & NEWLINE & NEWLINE & "    ****  You have died  ****" & NEWLINE & NEWLINE & resurrectText;
}

function endGameWin(message) {
    gameState.gameWon = true;
    return message & NEWLINE & NEWLINE & "    ****  You have won  ****" & NEWLINE & NEWLINE & "The game is over.";
}

// SCORE-UPD's WON-FLAG check: the moment every treasure has been both
// taken (banked in baseScore) and deposited (live in the trophy case),
// nudge the player toward the barrow rather than silently flipping
// wonFlag with no feedback.
// Also clears the map's INVISIBLE flag, mirroring real SCORE-UPD, which
// flips WON-FLAG and FCLEARs the map in the same breath.
function checkEndgameTrigger() {
    if ( !gameState.flags.wonFlag && handleScoreValue() >= TREASURE_MAX_SCORE ) {
        gameState.flags.wonFlag = true;
        objects.map.hidden = false;
        return NEWLINE & "An almost inaudible voice whispers in your ear, ""Look to your treasures for the final secret.""";
    }
    return "";
}

// Whether obj's fuel-stage messages should actually print this turn —
// ZIL's LIGHT-INT only tells you about a light source you're holding or
// standing next to, even though the underlying countdown always runs.
function lightSourceVisible(obj) {
    return obj.location == "player" || obj.location == gameState.currentRoom;
}

// LAMP-TABLE/CANDLE-TABLE: decrements brass_lantern/candles' fuel once per
// turn while lit, printing a dimmer warning at each stage boundary and
// permanently burning the light source out (RMUNGBIT) when fuel runs out.
// Simplified from ZIL's interrupt-queue table mechanics to a flat
// turn-counter — same text and stage thresholds, fewer moving parts.
LIGHT_FUEL_STAGES = {
    "brass_lantern" : {
        85 : "The lamp appears a bit dimmer.",
        15 : "The lamp is definitely dimmer now.",
        0  : "The lamp is nearly out."
    },
    "candles" : {
        15 : "The candles grow shorter.",
        5  : "The candles are becoming quite short.",
        0  : "The candles won't last long now."
    }
};

function tickLightFuel() {
    var notes = [];
    for ( var id in LIGHT_FUEL_STAGES ) {
        var obj = objects[ id ];
        if ( !obj.on || obj.fuel < 0 ) {
            continue;
        }
        obj.fuel -= 1;
        var visible = lightSourceVisible( obj );
        if ( obj.fuel < 0 ) {
            obj.on = false;
            obj.burnedOut = true;
            if ( visible ) {
                notes.append( "You'd better have more light than from the #obj.name#." );
            }
            continue;
        }
        var stages = LIGHT_FUEL_STAGES[ id ];
        if ( visible && stages.keyExists( obj.fuel ) ) {
            notes.append( stages[ obj.fuel ] );
        }
    }
    return notes.toList( NEWLINE );
}

// MATCH-FUNCTION's 2-turn burn: a struck match goes out on its own unless
// extinguished first.
function tickMatch() {
    if ( !objects.match.on ) {
        return "";
    }
    objects.match.fuel -= 1;
    if ( objects.match.fuel >= 0 ) {
        return "";
    }
    objects.match.on = false;
    objects.match.fuel = -1;
    return lightSourceVisible( objects.match ) ? "The match has gone out." : "";
}

// GRUE-FUNCTION/I-GRUE: fires each turn you remain in darkness after a 2-turn
// grace period. Probabilities verbatim from ZIL's GRUE-FCN: 65% harmless warning,
// ~17% grue description, ~17% death. Counter resets to 0 whenever you re-enter light.
function tickGrue() {
    if ( roomIsLit() ) {
        gameState.grueCounter = 0;
        return "";
    }
    gameState.grueCounter += 1;
    if ( gameState.grueCounter < 3 ) {
        return "";
    }
    var roll = randRange( 1, 100 );
    if ( roll <= 65 ) {
        return "You are likely to be eaten by a grue.";
    } else if ( roll <= 82 ) {
        return "The grue is a sinister, lurking presence in the dark places of the earth. Its favorite diet is adventurers, but its insatiable appetite is tempered by its fear of light. No grue has ever been seen by the light of day, and few have survived its fearsome jaws to tell the tale.";
    } else {
        return endGame( "Oh, no! You have walked into the slavering fangs of a lurking grue!" );
    }
}

// I-RFILL/I-REMPTY: the reservoir doesn't drain/refill the instant the bolt
// is turned — GATES-OPEN just starts an 8-turn countdown, after which
// lowTide flips to match it. Mirrors the bare-bones plumbing of those two
// routines (the TOUCHBIT-clearing redescription tricks and the loud-room/
// deep-canyon ambient lines and the boat-specific cases are river/vehicle
// flavor outside this task's scope, so only the lowTide flip itself and the
// reservoir's own trunk-reveal onEnter hook are ported).
function tickDam() {
    if ( gameState.gatesTransitionTurns <= 0 ) {
        return "";
    }
    gameState.gatesTransitionTurns -= 1;
    if ( gameState.gatesTransitionTurns > 0 ) {
        return "";
    }
    gameState.flags.lowTide = gameState.flags.gatesOpen;
    return "";
}

// DROWNINGS: indexed by water-level/2, exactly nine stages from ankle-deep
// to lungs-full before I-MAINT-ROOM floods the room outright at level 14.
DROWNINGS = [
    "up to your ankles.",
    "up to your shin.",
    "up to your knees.",
    "up to your hips.",
    "up to your waist.",
    "up to your chest.",
    "up to your neck.",
    "over your head.",
    "high in your lungs."
];

// I-MAINT-ROOM: once the leak starts (blue button), the water level rises
// by 1 every turn. While standing in the Maintenance Room it prints the
// current DROWNINGS stage; at level 14 the room floods for good (MUNG-ROOM)
// and, if the player is still in there, drowns them outright.
function tickMaintRoom() {
    if ( gameState.waterLevel <= 0 ) {
        return "";
    }
    var hereNow = gameState.currentRoom == "maintenance_room";
    var note = "";
    if ( hereNow ) {
        note = "The water level here is now " & DROWNINGS[ int( gameState.waterLevel / 2 ) + 1 ] ;
    }
    gameState.waterLevel += 1;
    if ( gameState.waterLevel >= 14 ) {
        gameState.maintenanceFlooded = true;
        if ( hereNow ) {
            return endGame( "I'm afraid you have done drowned yourself." );
        }
        return note;
    }
    // VEHBIT/INFLATED-BOAT check: while the leak is still rising (hasn't
    // hit full flood yet), being boated anywhere in the dam complex is
    // fatal on its own — the current sweeps the boat over the dam and
    // falls before the room itself ever finishes flooding.
    if ( gameState.boardedVehicle.len() &&
         ( gameState.currentRoom == "maintenance_room" || gameState.currentRoom == "dam_room" ||
           gameState.currentRoom == "dam_lobby" ) ) {
        return endGame( "The rising water carries the boat over the dam, down the river, and over
the falls.  Tsk, tsk." );
    }
    return note;
}

// Applies a blow outcome to the player; returns "" normally, or a death
// message if it was fatal (WINNER-RESULT).
function applyBlowToPlayer(outcome) {
    if ( outcome == BLOW_KILLED ) {
        gameState.playerStrengthAdjustment = -10000;
    } else if ( outcome == BLOW_LIGHT_WOUND ) {
        gameState.playerStrengthAdjustment -= 1;
        gameState.cureTimer = CURE_WAIT;
    } else if ( outcome == BLOW_SERIOUS_WOUND ) {
        gameState.playerStrengthAdjustment -= 2;
        gameState.cureTimer = CURE_WAIT;
    } else if ( outcome == BLOW_LOSE_WEAPON ) {
        var weapon = carriedWeapon();
        if ( weapon.len() ) {
            weapon.location = gameState.currentRoom;
        }
    }
    if ( fightStrength() <= 0 ) {
        return endGame( "It appears that that last blow was too much for you. I'm afraid you
are dead." );
    }
    return "";
}

// I-CURE: heals 1 point of wound every CURE_WAIT turns, re-arming itself
// while still wounded and going dormant (cureTimer 0) once fully healed.
function tickCure() {
    if ( gameState.cureTimer <= 0 ) {
        return "";
    }
    gameState.cureTimer -= 1;
    if ( gameState.cureTimer > 0 ) {
        return "";
    }
    if ( gameState.playerStrengthAdjustment < 0 ) {
        gameState.playerStrengthAdjustment += 1;
    }
    if ( gameState.playerStrengthAdjustment < 0 ) {
        gameState.cureTimer = CURE_WAIT;
    }
    return "";
}

// Applies a blow outcome to a villain; returns true if the villain is now
// dead/incapacitated (mirrors VILLAIN-RESULT's strength<=0 cleanup).
function applyBlowToVillain(villainId, outcome) {
    var villain = objects[ villainId ];
    if ( outcome == BLOW_KILLED ) {
        villain.strength = 0;
    } else if ( outcome == BLOW_LIGHT_WOUND ) {
        villain.strength = max( 0, villain.strength - 1 );
    } else if ( outcome == BLOW_SERIOUS_WOUND ) {
        villain.strength = max( 0, villain.strength - 2 );
    } else if ( outcome == BLOW_UNCONSCIOUS ) {
        villain.strength = -villain.strength;
    } else if ( outcome == BLOW_LOSE_WEAPON ) {
        var villainWeapon = objects.keyArray().filter( (id) => objects[ id ].location == villainId && objects[ id ].weapon );
        if ( villainWeapon.len() ) {
            objects[ villainWeapon[ 1 ] ].location = gameState.currentRoom;
            objects[ villainWeapon[ 1 ] ].hidden = false;
        }
    }
    return villain.strength <= 0;
}

// Incapacitated covers both KILLED (carcass vanishes, ZIL's VILLAIN-RESULT)
// and UNCONSCIOUS (he's still right there, just out cold — and in the real
// game could wake back up; not modeled here, so it's permanent).
function onVillainDefeated(villainId, outcome) {
    var name = objects[ villainId ].name;

    if ( outcome == BLOW_UNCONSCIOUS ) {
        if ( villainId == "troll" ) {
            gameState.flags.trollFlag = true;
            objects.axe.hidden = false;
            return "An unconscious troll is sprawled on the floor. All passages
out of the room are open.";
        }
        return "The #name# is knocked out cold.";
    }

    if ( villainId == "troll" ) {
        gameState.flags.trollFlag = true;
        objects.axe.hidden = false;
    } else if ( villainId == "thief" ) {
        var stash = objects.keyArray().filter( (id) => objects[ id ].location == "thief" );
        for ( var id in stash ) {
            objects[ id ].location = "treasure_room";
            objects[ id ].hidden = false;
        }
        objects.thief.location = "";
    }

    return "Almost as soon as the #name# breathes his last breath, a cloud
of sinister black fog envelops him, and when the fog lifts, the
carcass has disappeared" & ( villainId == "thief" ? ", save for the loot now scattered in the Treasure Room." : "." );
}

// HERO-BLOW + VILLAIN-BLOW collapsed into one synchronous exchange: the
// player swings first; if the villain survives and isn't staggered or
// freshly knocked unconscious, it swings straight back in the same turn.
// MIRROR-MUNG: attacking (MUNG/THROW/ATTACK in the original grammar — this
// engine only has ATTACK) either mirror smashes it, permanently disabling
// MIRROR-MIRROR's teleport for both linked rooms. No mechanical luck
// system exists here, so "seven years of bad luck" is flavor text only.
function handleAttack(villain, indirect) {
    if ( [ "mirror_1", "mirror_2" ].contains( villain.id ) ) {
        if ( gameState.flags.mirrorBroken ) {
            return "Haven't you done enough damage already?";
        }
        gameState.flags.mirrorBroken = true;
        return "You have broken the mirror. I hope you have a seven years' supply of
good luck handy.";
    }
    if ( !villain.actor ) {
        return "You can't attack the #villain.name#.";
    }
    if ( villain.strength <= 0 ) {
        return "Attacking the #villain.name# is pointless.";
    }

    var weapon = isStruct( indirect ) ? indirect : carriedWeapon();
    if ( !isStruct( weapon ) ) {
        return "You are unarmed.";
    }
    if ( weapon.location != "player" ) {
        return "You don't have that.";
    }

    var lines = [];

    var att = max( 1, fightStrength() );
    var def = villainStrength( villain.id, weapon.id );
    var heroOutcome = resolveBlowOutcome( att, def );
    lines.append( remark( HERO_MELEE[ heroOutcome ][ randRange( 1, HERO_MELEE[ heroOutcome ].len() ) ], weapon.name )
        .replaceNoCase( "{target}", villain.name, "all" ) );

    var villainDefeated = applyBlowToVillain( villain.id, heroOutcome );
    if ( villainDefeated ) {
        lines.append( onVillainDefeated( villain.id, heroOutcome ) );
        return lines.toList( NEWLINE );
    }

    if ( heroOutcome == BLOW_STAGGER || heroOutcome == BLOW_UNCONSCIOUS ) {
        return lines.toList( NEWLINE );
    }

    // Villain swings back.
    var villainAtt = villainStrength( villain.id, weapon.id );
    var playerDef = max( 0, fightStrength() );
    if ( playerDef <= 0 ) {
        return lines.toList( NEWLINE );
    }
    var villainOutcome = resolveBlowOutcome( villainAtt, playerDef );
    var villainWeapon = carriedWeapon();
    var messages = MELEE_TABLES[ VILLAIN_CONFIG[ villain.id ].messages ];
    lines.append( remark( messages[ villainOutcome ][ randRange( 1, messages[ villainOutcome ].len() ) ], villainWeapon.name ) );

    var deathMessage = applyBlowToPlayer( villainOutcome );
    if ( deathMessage.len() ) {
        lines.append( deathMessage );
    }

    return lines.toList( NEWLINE );
}

// V-THROW (gverbs.zil:1445), plus LANTERN's THROW case (1actions.zil,
// ROUTINE LANTERN) and the egg's "OPEN MUNG THROW" case (1actions.zil,
// ROUTINE EGG-OBJECT) for the two object-specific overrides this engine
// implements. `indirect` is "" (no target), the sentinel string "player"
// (PRSI == ME), or a resolved villain/other object struct.
function handleThrow(obj, indirect) {
    if ( obj.location != "player" ) {
        return "You don't have that.";
    }

    if ( obj.id == "egg" ) {
        obj.location = gameState.currentRoom;
        breakEgg();
        return "The egg falls to the ground and springs open, seriously damaged.";
    }

    if ( obj.id == "brass_lantern" ) {
        // LANTERN's THROW case: DISABLE the fuel interrupt, REMOVE-CAREFULLY
        // the lamp, MOVE BROKEN-LAMP HERE.
        objects.brass_lantern.on = false;
        objects.brass_lantern.location = "";
        objects.broken_lamp.location = gameState.currentRoom;
        objects.broken_lamp.hidden = false;
        return "The lamp has smashed into the floor, and the light has gone out.";
    }

    if ( isStruct( indirect ) && indirect.id == "player" ) {
        return endGame( "A terrific throw! The #obj.name# hits you squarely in the head. Normally,
this wouldn't do much damage, but by incredible mischance, you fall over
backwards trying to duck, and break your neck, justice being swift and
merciful in the Great Underground Empire." );
    }

    if ( isStruct( indirect ) && indirect.id == "troll" ) {
        var trollResult = trollGiveOrThrow( obj, "throw" );
        if ( trollResult.len() ) {
            return trollResult;
        }
    }

    if ( isStruct( indirect ) && indirect.actor ) {
        obj.location = gameState.currentRoom;
        return "The #indirect.name# ducks as the #obj.name# flies by and crashes to the ground.";
    }

    obj.location = gameState.currentRoom;
    return "Thrown.";
}

// Said in the Cyclops Room: he flees in terror at the name of his father's
// nemesis, smashing the east wall through to the Treasure Room area (sets
// magicFlag, which is also what unblocks Living Room's west door).
function handleOdysseus() {
    if ( gameState.currentRoom == "cyclops_room" && objects.cyclops.location == "cyclops_room" && !gameState.flags.cyclopsFlag ) {
        gameState.flags.cyclopsFlag = true;
        gameState.flags.magicFlag = true;
        objects.cyclops.location = "";
        return "The cyclops, hearing the name of his father's deadly nemesis, flees the room
by knocking down the wall on the east of the room.";
    }
    return "Wasn't he a sailor?";
}

// ---------------------------------------------------------------------
// Thief (ported from I-THIEF/STEAL-JUNK/ROB/DROP-JUNK in 1actions.zil).
// Simplified to a once-per-turn tick instead of a true random walk across
// every room each turn: a chance to relocate to a random room from a
// curated pool of the underground (post-troll) rooms, and — if that room
// is the player's current room — a chance to swipe one unguarded treasure
// lying on the ground there. Doesn't model his maze-specific odds, the
// "engrossed" combat penalty, or partial junk-dropping; loot (and the
// stiletto/bag) all surface in the Treasure Room on death.
// ---------------------------------------------------------------------

THIEF_ROOMS = [
    "troll_room", "ew_passage", "round_room", "deep_canyon", "damp_cave", "loud_room",
    "ns_passage", "chasm_room", "engravings_cave", "egypt_room", "dome_room", "torch_room",
    "north_temple", "south_temple", "dam_room", "dam_lobby", "maintenance_room",
    "cyclops_room", "strange_passage", "gallery", "studio", "east_of_chasm", "cellar",
    "living_room", "kitchen", "attic", "mirror_room_1", "mirror_room_2", "small_cave",
    "tiny_cave", "cold_passage", "narrow_passage", "winding_passage", "twisting_passage",
    "atlantis_room", "reservoir_north", "treasure_room"
];

// Returns an extra line to print after the command's own output, or "" if
// nothing notable happened (the thief moved on unseen, as usual).
function tickThief() {
    if ( objects.thief.strength <= 0 ) {
        return "";
    }

    // Only wanders off-screen — once he's sharing a room with the player
    // (encountered, mid-theft, or mid-fight) he stays until the player
    // leaves or he's defeated, instead of randomly vanishing mid-exchange.
    if ( objects.thief.location != gameState.currentRoom ) {
        if ( randRange( 1, 100 ) <= 35 ) {
            objects.thief.location = THIEF_ROOMS[ randRange( 1, THIEF_ROOMS.len() ) ];
        }
        if ( objects.thief.location != gameState.currentRoom ) {
            objects.thief.hidden = true;
            return "";
        }
    }

    objects.thief.hidden = false;

    var loot = objects.keyArray().filter(
        (id) => objects[ id ].location == gameState.currentRoom && objects[ id ].treasureValue > 0
    );
    if ( loot.len() && randRange( 1, 100 ) <= 30 ) {
        var stolenId = loot[ randRange( 1, loot.len() ) ];
        // The egg is fragile enough that the thief's grab-and-run snatches
        // it roughly off the ground; breaks it just like any other rough
        // handling (egg fragility is otherwise drop-triggered per ZIL).
        if ( stolenId == "egg" ) {
            breakEgg();
            objects.broken_egg.location = "thief";
            objects.broken_egg.hidden = true;
            if ( objects.broken_canary.location == "broken_egg" ) {
                objects.broken_canary.hidden = true;
            }
            return "You suddenly notice that the jewel-encrusted egg is gone, and you catch a
glimpse of someone with a bag disappearing into the gloom -- it sounded
like something inside the egg cracked.";
        }
        objects[ stolenId ].location = "thief";
        objects[ stolenId ].hidden = true;
        return "You suddenly notice that the #objects[ stolenId ].name# is gone.";
    }

    return "";
}

// CYCLOPS-FCN's GIVE handling: food calms him a little (flavor only here —
// the real CYCLOWRATH anger meter isn't modeled), water puts him to sleep
// (cyclopsFlag), anything else is rebuffed.
function handleGiveCyclops(obj) {
    if ( obj.id == "lunch" ) {
        obj.location = "";
        return "The cyclops says ""Mmm Mmm. I love hot peppers! But oh, could I use
a drink.""";
    }
    if ( obj.id == "water" || ( obj.id == "bottle" && objects.water.location == "bottle" ) ) {
        if ( gameState.flags.cyclopsFlag ) {
            return "The cyclops is already fast asleep.";
        }
        objects.water.location = "";
        objects.bottle.location = gameState.currentRoom;
        objects.bottle.open = true;
        gameState.flags.cyclopsFlag = true;
        return "The cyclops takes the bottle, checks that it's open, and drinks the water.
A moment later, he lets out a yawn that nearly blows you over, and then
falls fast asleep (what did you put in that drink, anyway?).";
    }
    if ( obj.id == "garlic" ) {
        return "The cyclops may be hungry, but there is a limit.";
    }
    return "The cyclops is not so stupid as to eat THAT!";
}

// TROLL-FCN's GIVE/THROW handling: only fires while he's alive and present.
// Returning his own axe calms him into taking it back; any other knife/
// sword/axe has a 1-in-5 chance of being his last meal (kills him outright,
// opening the room for good, same as a combat win) or otherwise gets thrown
// right back at you; anything else is just eaten and gone for good. Shared
// by handleGive and handleThrow since ZIL's TROLL-FCN treats <VERB? THROW
// GIVE> identically.
function trollGiveOrThrow(obj, verb) {
    if ( objects.troll.location != gameState.currentRoom || objects.troll.strength <= 0 ) {
        return "";
    }

    if ( obj.id == "axe" ) {
        objects.axe.location = "troll_room";
        objects.axe.hidden = true;
        return "The troll scratches his head in confusion, then takes the axe.";
    }

    var verbPhrase = verb == "throw"
        ? "The troll, who is remarkably coordinated, catches the #obj.name#"
        : "The troll, who is not overly proud, graciously accepts the gift";

    if ( [ "knife", "sword", "axe" ].contains( obj.id ) ) {
        if ( randRange( 1, 100 ) <= 20 ) {
            obj.location = "";
            objects.troll.location = "";
            objects.troll.strength = 0;
            gameState.flags.trollFlag = true;
            return verbPhrase & " and eats it hungrily. Poor troll, he dies from an internal
hemorrhage and his carcass disappears in a sinister black fog.";
        }
        obj.location = gameState.currentRoom;
        return verbPhrase & " and, being for the moment sated, throws it back. Fortunately, the
troll has poor control, and the #obj.name# falls to the floor. He does
not look pleased.";
    }

    obj.location = "";
    return verbPhrase & " and not having the most discriminating tastes, gleefully eats it.";
}

function handleGive(obj, indirect) {
    if ( obj.location != "player" ) {
        return "You don't have that.";
    }
    if ( indirect.id == "cyclops" ) {
        return handleGiveCyclops( obj );
    }
    if ( indirect.id == "troll" ) {
        var trollResult = trollGiveOrThrow( obj, "give" );
        if ( trollResult.len() ) {
            return trollResult;
        }
    }
    if ( !indirect.actor ) {
        return "You can't give things to the #indirect.name#.";
    }
    if ( indirect.container && indirect.open ) {
        obj.location = indirect.id;
        return "Given.";
    }
    return "The #indirect.name# doesn't want that.";
}

// FIX-MAINT-LEAK: putty stops the leak outright, resets WATER-LEVEL to its
// "stopped" sentinel, and cancels the flood timer.
function fixMaintLeak() {
    gameState.waterLevel = -1;
    return "By some miracle of Zorkian technology, you have managed to stop the
leak in the dam.";
}

// FIX-BOAT: putty doesn't reinflate the punctured boat — it moves the
// (still deflated) inflatable_boat to wherever the punctured one was lying,
// and the punctured one is gone for good. Re-inflating it afterward is the
// existing pump mechanic (handleInflate).
function fixBoat() {
    objects.inflatable_boat.location = objects.punctured_boat.location;
    objects.punctured_boat.location = "";
    return "Well done. The boat is repaired.";
}

function handlePut(obj, indirect) {
    if ( obj.location != "player" ) {
        return "You don't have that.";
    }
    if ( obj.id == "putty" && indirect.id == "leak" ) {
        return fixMaintLeak();
    }
    if ( obj.id == "putty" && indirect.id == "punctured_boat" ) {
        return fixBoat();
    }
    // BASKET-F: the basket only acts as a container from whichever end of
    // the dumbwaiter shaft it's actually at (raised_basket); the decoy
    // object at the other end can't hold anything.
    if ( indirect.id == "lowered_basket" ) {
        return "The basket is at the other end of the chain.";
    }
    if ( !indirect.container ) {
        return "You can't put things in the #indirect.name#.";
    }
    if ( obj.id == indirect.id ) {
        return "You can't put something inside itself.";
    }
    if ( indirect.openable && !indirect.open ) {
        return "The #indirect.name# is closed.";
    }
    obj.location = indirect.id;
    return "Done.";
}

// RUG-FCN's counterpart for the dome: tying the rope to the railing sets
// domeFlag, which is what actually unblocks Dome Room's "down" exit.
function handleTie(obj, indirect) {
    if ( obj.id == "rope" && indirect.id == "railing" && gameState.currentRoom == "dome_room" ) {
        gameState.flags.domeFlag = true;
        objects.rope.location = "dome_room";
        // Now described entirely by Dome/Torch Room's own prose (domeFlag),
        // same pattern as trophy_case/front_door — avoid double mention.
        objects.rope.scenery = true;
        return "The rope is now tied to the railing, and its other end drops over the side.";
    }
    return "You can't tie those together.";
}

function handleUnlock(obj, indirect) {
    if ( !obj.locked ) {
        return "It's not locked.";
    }
    if ( !isStruct( indirect ) ) {
        return "Unlock it with what?";
    }
    if ( indirect.location != "player" ) {
        return "You don't have that.";
    }
    if ( obj.unlocksWith == indirect.id ) {
        obj.locked = false;
        return "Unlocked.";
    }
    return "The #indirect.name# doesn't fit the lock.";
}

function handleLock(obj, indirect) {
    if ( obj.locked ) {
        return "It's already locked.";
    }
    if ( !isStruct( indirect ) ) {
        return "Lock it with what?";
    }
    if ( indirect.location != "player" ) {
        return "You don't have that.";
    }
    if ( obj.unlocksWith == indirect.id ) {
        obj.locked = true;
        return "Locked.";
    }
    return "The #indirect.name# doesn't fit the lock.";
}

// V-POUR-ON: pouring putty onto something is really PUT PUTTY ON X under
// the hood, so it reuses the same fixMaintLeak/fixBoat handling as "put".
// Otherwise only water can be poured: onto an open flame (candles/torch —
// not the battery-powered lamp) it's FLAMING? and gets extinguished;
// anywhere else it just spills onto the ground and evaporates.
function handlePour(obj, indirect) {
    if ( obj.id == "putty" ) {
        if ( obj.location != "player" ) {
            return "You aren't holding that.";
        }
        if ( isStruct( indirect ) ) {
            if ( indirect.id == "leak" ) {
                return fixMaintLeak();
            }
            if ( indirect.id == "punctured_boat" ) {
                return fixBoat();
            }
        }
        return "You can't pour that.";
    }
    if ( !obj.drinkable ) {
        return "You can't pour that.";
    }
    // Water always sits inside the bottle (never directly held), so this
    // checks the container is held, not the water object itself — same as
    // the global_water exception in handleDrink.
    if ( obj.id != "global_water" ) {
        var container = objects[ obj.location ];
        if ( !isStruct( container ) || container.location != "player" ) {
            return "You aren't holding that.";
        }
    }
    if ( isStruct( indirect ) && [ "candles", "torch" ].contains( indirect.id ) && indirect.on ) {
        indirect.on = false;
        obj.location = "";
        return "The #indirect.name# is extinguished.";
    }
    obj.location = gameState.currentRoom;
    return "You pour the #obj.name# onto the ground.";
}

function handleFill(obj, indirect) {
    if ( !obj.container ) {
        return "You can't fill that.";
    }
    if ( !isStruct( indirect ) ) {
        return "Fill it with what?";
    }
    if ( !indirect.drinkable ) {
        return "You can't fill it with that.";
    }
    if ( indirect.location != "player" ) {
        return "You don't have that.";
    }
    indirect.location = obj.id;
    return "The #obj.name# is now full of #indirect.name#.";
}

// IBOAT-FUNCTION simplified: pumping the folded plastic boat with the pump
// swaps it for the inflated (usable) boat. Actually sailing it on the
// river rooms isn't implemented (Task 6).
function handleInflate(obj, indirect) {
    if ( obj.id != "inflatable_boat" ) {
        return "You can't inflate that.";
    }
    if ( !isStruct( indirect ) || indirect.id != "pump" ) {
        return "You'll need the pump to inflate it.";
    }
    if ( indirect.location != "player" ) {
        return "You don't have the pump.";
    }
    var whereItWas = obj.location;
    obj.location = "";
    objects.inflated_boat.location = whereItWas;
    return "The boat inflates and looks seaworthy.";
}

// Custom per-exit routines that are more than a simple flag/open check
// (ZIL's "PER <routine>" exits). Each returns either a room id (string) on
// success, or a struct { "blocked" : "message" } on failure.
PER_EXITS = {
    // GRATING-EXIT: only usable once the grate has been spotted from below,
    // and only passable once it's been unlocked and opened.
    "grating_exit" : () => {
        if ( !gameState.flags.grateRevealed ) {
            return { "blocked" : "You can't go that way." };
        }
        if ( !objects.grate.open ) {
            return { "blocked" : "The grating is closed!" };
        }
        return "grating_room";
    },
    // MAZE-DIODES: one-way "diode" passages with a fixed (not random)
    // far-side destination per source room, exactly as in 1actions.zil.
    "maze_diodes" : () => {
        var destinationByRoom = {
            "maze_2"  : "maze_4",
            "maze_7"  : "dead_end_1",
            "maze_9"  : "maze_11",
            "maze_12" : "maze_5"
        };
        println(
"You won't be able to get back up to the tunnel you are going through
when it gets to the next room."
        );
        return destinationByRoom[ gameState.currentRoom ];
    },
    // UP-CHIMNEY-FUNCTION: must be carrying the lamp (to see) and not much
    // else, or you can't squeeze up the narrow chimney.
    "up_chimney" : () => {
        var carried = carriedIds();
        if ( carried.isEmpty() ) {
            return { "blocked" : "Going up empty-handed is a bad idea." };
        }
        if ( carried.contains( "brass_lantern" ) && carried.len() <= 2 ) {
            return "kitchen";
        }
        return { "blocked" : "You can't get up there with what you're carrying." };
    },
    // MUNG-ROOM's effect once I-MAINT-ROOM floods the Maintenance Room for
    // good: it's permanently unenterable after that.
    "maintenance_room_entrance" : () => {
        if ( gameState.maintenanceFlooded ) {
            return { "blocked" : "The room is full of water and cannot be entered." };
        }
        return "maintenance_room";
    }
};

// Moves the player into a room and fires its onEnter hook (ZIL's M-ENTER),
// e.g. GRATING-ROOM revealing the grate. Most onEnter behavior in the real
// game is puzzle-specific and isn't implemented yet (see project tasks).
// A hook may itself relocate the player again (BATS-ROOM's FLY-ME, via
// gameState.currentRoom) — re-read currentRoom afterward so the final
// description matches wherever the player actually ended up.
function enterRoom(roomId) {
    gameState.currentRoom = roomId;
    var room = rooms[ roomId ];
    // TOUCHBIT: has the player ever been here. Only south_temple's value is
    // actually read (JIGS-UP's ghost-limbo branch), but set it everywhere
    // for consistency.
    room.touched = true;
    if ( room.keyExists( "onEnter" ) ) {
        var hookResult = room.onEnter();
        // Most onEnter hooks are side-effect-only (flip a flag, reveal an
        // object) and return nothing; a few (the barrow's ending) return
        // text that should replace the room description entirely.
        if ( !isNull( hookResult ) && isSimpleValue( hookResult ) && hookResult.len() ) {
            return hookResult;
        }
    }
    return describeRoom( rooms[ gameState.currentRoom ] );
}

function handleGo(direction) {
    if ( direction == "land" ) {
        return handleLand();
    }

    // DEAD-FUNCTION's one WALK override: a ghost can't squeeze through the
    // narrow passage west of the Timber Room.
    if ( gameState.flags.ghost && gameState.currentRoom == "timber_room" && direction == "west" ) {
        return "You cannot enter in your condition.";
    }

    // VEHBIT check (RBOAT-FUNCTION's M-BEG WALK handling): once aboard the
    // boat on the river itself, only LAND/EAST/WEST fall through to normal
    // exit handling (the room's own exits decide whether east/west are a
    // valid landing or a blocked message); every other direction — notably
    // UP and DOWN, since the current carries you downstream automatically —
    // gets the same redirect. The reverse case (walking into a river room
    // without a boat) needs no extra check: none of river_1-5's exits are
    // reachable except by LAUNCH, matching NONLANDBIT in the data rather
    // than at the engine layer.
    var boardedOnRiver = gameState.boardedVehicle.len() && RIVER_ROOMS.contains( gameState.currentRoom );

    if ( boardedOnRiver && direction != "east" && direction != "west" ) {
        return "Read the label for the boat's instructions.";
    }

    var room = rooms[ gameState.currentRoom ];
    if ( !room.exits.keyExists( direction ) ) {
        return "You can't go that way.";
    }

    var exit = room.exits[ direction ];

    // Walking east/west off the river (instead of LAND) still beaches the
    // boat, exactly like landing — RBOAT-FUNCTION lets WALK EAST/WEST fall
    // through to the room's own exit, but the boat comes ashore with you
    // either way.
    function disembark(description) {
        if ( !boardedOnRiver ) {
            return description;
        }
        var boatId = gameState.boardedVehicle;
        gameState.boardedVehicle = "";
        objects[ boatId ].location = gameState.currentRoom;
        return description;
    }

    if ( isSimpleValue( exit ) ) {
        return disembark( enterRoom( exit ) );
    }

    if ( exit.keyExists( "blocked" ) ) {
        return exit.blocked;
    }

    if ( exit.keyExists( "per" ) ) {
        var outcome = PER_EXITS[ exit.per ]();
        return isSimpleValue( outcome ) ? disembark( enterRoom( outcome ) ) : outcome.blocked;
    }

    if ( exit.keyExists( "to" ) ) {
        if ( exit.keyExists( "requiresOpen" ) && !objects[ exit.requiresOpen ].open ) {
            return exit.keyExists( "blockedMessage" ) ? exit.blockedMessage : "You can't go that way.";
        }
        if ( exit.keyExists( "requiresFlag" ) && !gameState.flags[ exit.requiresFlag ] ) {
            return exit.keyExists( "blockedMessage" ) ? exit.blockedMessage : "You can't go that way.";
        }
        if ( exit.keyExists( "requiresNotCarrying" ) && carriedIds().contains( exit.requiresNotCarrying ) ) {
            return exit.keyExists( "blockedMessage" ) ? exit.blockedMessage : "You can't go that way.";
        }
        if ( exit.keyExists( "requiresEmptyHanded" ) && !carriedIds().isEmpty() ) {
            return exit.keyExists( "blockedMessage" ) ? exit.blockedMessage : "You can't go that way.";
        }
        return disembark( enterRoom( exit.to ) );
    }

    return "You can't go that way.";
}

function capitalizeVerb(verb) {
    return verb.left( 1 ).ucase() & verb.right( verb.len() - 1 );
}

function dispatchOneObjectVerb(verb, obj) {
    switch ( verb ) {
        case "examine":    return handleExamine( obj );
        case "take":       return handleTake( obj );
        case "drop":       return handleDrop( obj );
        case "open":       return handleOpen( obj );
        case "close":      return handleClose( obj );
        case "read":       return handleRead( obj );
        case "drink":      return handleDrink( obj );
        case "eat":        return handleEat( obj );
        case "climb":      return handleClimb( obj );
        case "wave":       return handleWave( obj );
        case "ring":       return handleRing( obj );
        case "wind":       return handleWind( obj );
        case "push":       return handlePush( obj );
        case "board":      return handleBoard( obj );
        case "search":     return handleSearch( obj );
        case "light":      return handleLight( obj );
        case "extinguish": return handleExtinguish( obj );
        case "turn_on":    return handleTurnOn( obj );
        case "turn_off":   return handleExtinguish( obj );
        case "raise":      return handleRaise( obj );
        case "lower":      return handleLower( obj );
        case "kick":       return handleKick( obj );
        case "cut":        return handleCut( obj );
        case "look_under": return handleLookUnder( obj );
        case "follow":     return handleFollow( obj );
        case "wake":       return handleWake( obj );
        case "answer":     return handleAnswer( obj );
    }
    return "I don't know how to do that yet.";
}

function dispatchTwoObjectVerbCore(verb, obj1, indirect) {
    switch ( verb ) {
        case "give":    return handleGive( obj1, indirect );
        case "put":     return handlePut( obj1, indirect );
        case "tie":     return handleTie( obj1, indirect );
        case "unlock":  return handleUnlock( obj1, indirect );
        case "lock":    return handleLock( obj1, indirect );
        case "pour":    return handlePour( obj1, indirect );
        case "fill":    return handleFill( obj1, indirect );
        case "inflate": return handleInflate( obj1, indirect );
        case "burn":    return handleBurn( obj1, indirect );
        case "dig":     return handleDig( obj1, indirect );
        case "turn":    return handleTurn( obj1, indirect );
        case "attack":  return handleAttack( obj1, indirect );
        case "throw":   return handleThrow( obj1, indirect );
        case "rub":     return handleRub( obj1, indirect );
    }
    return "I don't know how to do that yet.";
}

// Resolves the indirect object (if any) and dispatches. Split out of
// dispatchTwoObjectVerb so orphaning (missing direct object) and
// disambiguation can resume straight into this once the direct object is
// known, without re-parsing the original sentence.
function finishTwoObjectVerb(verb, obj1, obj2Words) {
    var config = TWO_OBJECT_VERBS[ verb ];

    var indirect = "";
    if ( obj2Words.len() == 1 && ( obj2Words[ 1 ] == "me" || obj2Words[ 1 ] == "myself" ) ) {
        // PRSI == ME has no vocabulary entry to resolve against (there's no
        // player object in `objects`); special-case it here so handleThrow
        // can see a struct-shaped "it's the player" sentinel.
        indirect = { "id" : "player", "name" : "yourself", "actor" : false };
    } else if ( obj2Words.len() ) {
        var resolved2 = resolveObject( obj2Words, gameState.currentRoom );
        if ( !isSimpleValue( resolved2 ) ) {
            if ( resolved2.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = {
                    "type" : "disambiguate", "verb" : verb, "resumeKind" : "twoIndirect",
                    "directObjectId" : obj1.id, "candidates" : resolved2.candidates
                };
            }
            return resolved2.error;
        }
        indirect = objects[ resolved2 ];
    } else if ( config.requireSecond ) {
        gameState.pendingPrompt = { "type" : "orphanIndirect", "verb" : verb, "directObjectId" : obj1.id };
        return config.prompt;
    }

    return dispatchTwoObjectVerbCore( verb, obj1, indirect );
}

function dispatchTwoObjectVerb(verb, restWords) {
    var config = TWO_OBJECT_VERBS[ verb ];

    var splitIndex = 0;
    for ( var i = 1; i <= restWords.len(); i++ ) {
        if ( config.prepositions.contains( restWords[ i ] ) ) {
            splitIndex = i;
            break;
        }
    }

    var obj1Words = splitIndex > 0 ? sliceWords( restWords, 1, splitIndex - 1 ) : restWords;
    var obj2Words = splitIndex > 0 ? sliceWords( restWords, splitIndex + 1, restWords.len() - splitIndex ) : [];

    if ( obj1Words.isEmpty() ) {
        gameState.pendingPrompt = { "type" : "orphanOne", "verb" : verb, "kind" : "two", "obj2Words" : obj2Words };
        return "#capitalizeVerb( verb )# what?";
    }

    var resolved1 = resolveObject( obj1Words, gameState.currentRoom );
    if ( !isSimpleValue( resolved1 ) ) {
        if ( resolved1.keyExists( "candidates" ) ) {
            gameState.pendingPrompt = {
                "type" : "disambiguate", "verb" : verb, "resumeKind" : "twoDirect", "obj2Words" : obj2Words,
                "candidates" : resolved1.candidates
            };
        }
        return resolved1.error;
    }
    var obj1 = objects[ resolved1 ];

    return finishTwoObjectVerb( verb, obj1, obj2Words );
}

function dispatchCommand(input) {
    var words = tokenize( input ).filter( (w) => !NOISE_WORDS.contains( w ) );
    if ( words.isEmpty() ) {
        return "I beg your pardon?";
    }

    if ( words.len() == 1 && DIRECTION_WORDS.keyExists( words[ 1 ] ) ) {
        return handleGo( DIRECTION_WORDS[ words[ 1 ] ] );
    }

    var verbInfo = extractVerb( words );
    if ( !verbInfo.found ) {
        gameState.lastUnknownWord = words[ 1 ];
        return "I don't understand that.";
    }

    var verb = verbInfo.verb;
    var rest = words.len() > verbInfo.consumed ? sliceWords( words, verbInfo.consumed + 1, words.len() - verbInfo.consumed ) : [];

    if ( verb == "go" ) {
        var directionWord = rest.filter( (w) => DIRECTION_WORDS.keyExists( w ) );
        return directionWord.len() ? handleGo( DIRECTION_WORDS[ directionWord[ 1 ] ] ) : "Go where?";
    }

    // DEAD-FUNCTION: as a ghost, every verb but WALK/SAVE is intercepted
    // here before any normal dispatch (object resolution included).
    if ( gameState.flags.ghost ) {
        var ghostResult = handleGhostVerb( verb );
        if ( ghostResult.len() ) {
            return ghostResult;
        }
    }

    if ( ZERO_OBJECT_VERBS.contains( verb ) ) {
        switch ( verb ) {
            case "look":      return handleLook();
            case "inventory": return handleInventory();
            case "pray":      return handlePray();
            case "score":     return handleScore();
            case "diagnose":  return handleDiagnose();
            case "launch":    return handleLaunch();
            case "odysseus":  return handleOdysseus();
            case "save":      return handleSave();
        }
    }

    if ( verb == "smell" ) {
        if ( rest.isEmpty() ) {
            return handleSmell( "" );
        }
        // GAS-PSEUDO: "GAS"/"ODOR" are pseudo-object nouns local to the
        // Smelly/Gas Rooms in ZIL — not real objects, so not resolvable via
        // resolveObject. Elsewhere those words just fall through to the
        // normal "I don't know that word" handling below, same as ZIL.
        if ( rest.len() == 1 && [ "gas", "odor" ].contains( rest[ 1 ] ) && GAS_SMELL_ROOMS.contains( gameState.currentRoom ) ) {
            return "It smells like coal gas in here.";
        }
        var smelled = resolveObject( rest, gameState.currentRoom );
        if ( !isSimpleValue( smelled ) ) {
            if ( smelled.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = { "type" : "disambiguate", "verb" : verb, "resumeKind" : "smell", "candidates" : smelled.candidates };
            }
            return smelled.error;
        }
        return handleSmell( objects[ smelled ] );
    }

    // "LISTEN TO/FOR OBJECT" in ZIL syntax; strip a leading "to"/"for" if
    // present, but a bare noun phrase ("listen troll") also works here.
    if ( verb == "listen" ) {
        var listenRest = rest.len() && [ "to", "for" ].contains( rest[ 1 ] )
            ? sliceWords( rest, 2, rest.len() - 1 )
            : rest;
        if ( listenRest.isEmpty() ) {
            return handleListenVerb( "" );
        }
        var heard = resolveObject( listenRest, gameState.currentRoom );
        if ( !isSimpleValue( heard ) ) {
            if ( heard.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = { "type" : "disambiguate", "verb" : verb, "resumeKind" : "listen", "candidates" : heard.candidates };
            }
            return heard.error;
        }
        return handleListenVerb( objects[ heard ] );
    }

    // "turn <object> on/off" (ZIL's own SYNTAX form, object between verb and
    // particle) — distinct from the "turn on <object>" two-word-verb form
    // extractVerb() already catches. Needed so pronouns work here too
    // ("take lamp. turn it on."), since the pronoun sits where extractVerb's
    // fixed two-word lookahead can't see it.
    if ( verb == "turn" && rest.len() && [ "on", "off" ].contains( rest[ rest.len() ] ) ) {
        var turnVerb = rest[ rest.len() ] == "on" ? "turn_on" : "turn_off";
        var turnObjWords = sliceWords( rest, 1, rest.len() - 1 );
        if ( turnObjWords.isEmpty() ) {
            gameState.pendingPrompt = { "type" : "orphanOne", "verb" : turnVerb, "kind" : "one" };
            return "#capitalizeVerb( turnVerb )# what?";
        }
        var turnResolved = resolveObject( turnObjWords, gameState.currentRoom );
        if ( !isSimpleValue( turnResolved ) ) {
            if ( turnResolved.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = { "type" : "disambiguate", "verb" : turnVerb, "resumeKind" : "one", "candidates" : turnResolved.candidates };
            }
            return turnResolved.error;
        }
        return dispatchOneObjectVerb( turnVerb, objects[ turnResolved ] );
    }

    if ( TWO_OBJECT_VERBS.keyExists( verb ) ) {
        return dispatchTwoObjectVerb( verb, rest );
    }

    if ( ONE_OBJECT_VERBS.contains( verb ) ) {
        if ( rest.isEmpty() ) {
            gameState.pendingPrompt = { "type" : "orphanOne", "verb" : verb, "kind" : "one" };
            return "#capitalizeVerb( verb )# what?";
        }

        if ( MULTI_OBJECT_VERBS.contains( verb ) ) {
            var group = resolveObjectGroup( rest, verb );
            if ( group.keyExists( "ids" ) ) {
                gameState.lastObjectIds = group.ids;
                var messages = [];
                for ( var id in group.ids ) {
                    messages.append( dispatchOneObjectVerb( verb, objects[ id ] ) );
                }
                return messages.toList( NEWLINE );
            }
            if ( group.keyExists( "error" ) ) {
                return group.error;
            }
            // group.single == true: fall through to ordinary single-object resolution.
        }

        var resolved = resolveObject( rest, gameState.currentRoom );
        if ( !isSimpleValue( resolved ) ) {
            if ( resolved.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = { "type" : "disambiguate", "verb" : verb, "resumeKind" : "one", "candidates" : resolved.candidates };
            }
            return resolved.error;
        }
        return dispatchOneObjectVerb( verb, objects[ resolved ] );
    }

    return "I don't know how to do that yet.";
}

// Resumes whatever object-targeted verb a disambiguation/orphan prompt was
// originally raised for, once the missing/ambiguous object is known.
function dispatchByKind(verb, kind, obj) {
    switch ( kind ) {
        case "smell":  return handleSmell( obj );
        case "listen": return handleListenVerb( obj );
        default:       return dispatchOneObjectVerb( verb, obj );
    }
}

// Resolves a pending orphan/disambiguation question against the next input
// line. Returns { "message", "stillPending", "executed" } — stillPending
// means another question was raised (e.g. the answer itself was ambiguous,
// or a two-object verb's direct object resolved but the indirect object is
// now missing), so processCommand must not charge a turn or run the tick
// sequence yet.
function resolvePendingPromptTurn(input) {
    var prompt = gameState.pendingPrompt;
    clearPendingPrompt();
    var resultText = "";

    if ( prompt.type == "orphanOne" ) {
        var words = tokenize( input ).filter( (w) => !NOISE_WORDS.contains( w ) );
        if ( words.isEmpty() ) {
            return { "message" : "Never mind.", "stillPending" : false, "executed" : false };
        }
        var resolved = resolveObject( words, gameState.currentRoom );
        if ( !isSimpleValue( resolved ) ) {
            if ( resolved.keyExists( "candidates" ) ) {
                gameState.pendingPrompt = {
                    "type" : "disambiguate", "verb" : prompt.verb,
                    "resumeKind" : prompt.kind == "two" ? "twoDirect" : prompt.kind,
                    "obj2Words" : prompt.kind == "two" ? prompt.obj2Words : [],
                    "candidates" : resolved.candidates
                };
                return { "message" : resolved.error, "stillPending" : true };
            }
            return { "message" : resolved.error, "stillPending" : false, "executed" : false };
        }
        resultText = prompt.kind == "two"
            ? finishTwoObjectVerb( prompt.verb, objects[ resolved ], prompt.obj2Words )
            : dispatchByKind( prompt.verb, prompt.kind, objects[ resolved ] );

    } else if ( prompt.type == "orphanIndirect" ) {
        var indirectWords = tokenize( input ).filter( (w) => !NOISE_WORDS.contains( w ) );
        if ( indirectWords.isEmpty() ) {
            return { "message" : "Never mind.", "stillPending" : false, "executed" : false };
        }
        resultText = finishTwoObjectVerb( prompt.verb, objects[ prompt.directObjectId ], indirectWords );

    } else if ( prompt.type == "disambiguate" ) {
        var matches = matchAnswerAgainstCandidates( input, prompt.candidates );
        if ( matches.len() != 1 ) {
            return { "message" : "I still can't tell which one you mean.", "stillPending" : false, "executed" : false };
        }
        var chosenId = matches[ 1 ];
        switch ( prompt.resumeKind ) {
            case "one": case "smell": case "listen":
                resultText = dispatchByKind( prompt.verb, prompt.resumeKind, objects[ chosenId ] );
                break;
            case "twoDirect":
                resultText = finishTwoObjectVerb( prompt.verb, objects[ chosenId ], prompt.obj2Words );
                break;
            case "twoIndirect":
                resultText = dispatchTwoObjectVerbCore( prompt.verb, objects[ prompt.directObjectId ], objects[ chosenId ] );
                break;
            default:
                resultText = "I don't know how to do that yet.";
        }

    } else {
        return { "message" : "Never mind.", "stillPending" : false, "executed" : false };
    }

    return {
        "message" : resultText,
        "stillPending" : gameState.pendingPrompt.type.len() > 0,
        "executed" : !( gameState.pendingPrompt.type.len() > 0 )
    };
}

// Splits a raw input line into independent command clauses on "." / "then"
// (always) and "and" (only when it's joining two whole commands rather than
// an object list — detected by checking whether the next word is itself a
// known verb/direction; see ZIL's CLAUSE/PARSER). Returns an array of
// word-arrays.
function splitClauses(input) {
    var tokens = reMatch( "[a-zA-Z']+|[.]", input.lcase() );
    var clauses = [];
    var current = [];
    for ( var i = 1; i <= tokens.len(); i++ ) {
        var t = tokens[ i ];
        if ( t == "." || t == "then" ) {
            if ( current.len() ) {
                clauses.append( current );
            }
            current = [];
            continue;
        }
        if ( t == "and" ) {
            var next = i < tokens.len() ? tokens[ i + 1 ] : "";
            if ( current.len() && ( VERB_INDEX.keyExists( next ) || DIRECTION_WORDS.keyExists( next ) ) ) {
                clauses.append( current );
                current = [];
                continue;
            }
        }
        current.append( t );
    }
    if ( current.len() ) {
        clauses.append( current );
    }
    return clauses;
}

// The per-turn demon/fuse sequence, run once per actually-executed command
// (not per clarifying question — see processClauseTurn()).
function runTickSequence() {
    var suffix = "";

    var riverNote = tickRiver();
    if ( riverNote.len() ) {
        suffix &= NEWLINE & riverNote;
    }

    // KILL-INTERRUPTS: the thief and the lantern/match fuel timers are
    // permanently disabled after the first death.
    if ( !gameState.playerDead && gameState.deaths == 0 ) {
        var thiefNote = tickThief();
        if ( thiefNote.len() ) {
            suffix &= NEWLINE & thiefNote;
        }
    }

    if ( gameState.deaths == 0 ) {
        var lightFuelNote = tickLightFuel();
        if ( lightFuelNote.len() ) {
            suffix &= NEWLINE & lightFuelNote;
        }

        var matchNote = tickMatch();
        if ( matchNote.len() ) {
            suffix &= NEWLINE & matchNote;
        }
    }

    if ( !gameState.playerDead ) {
        tickCure();
    }

    if ( !gameState.playerDead ) {
        var grueNote = tickGrue();
        if ( grueNote.len() ) {
            suffix &= NEWLINE & grueNote;
        }
    }

    var damNote = tickDam();
    if ( damNote.len() ) {
        suffix &= NEWLINE & damNote;
    }

    if ( !gameState.playerDead ) {
        var maintRoomNote = tickMaintRoom();
        if ( maintRoomNote.len() ) {
            suffix &= NEWLINE & maintRoomNote;
        }
    }

    if ( !gameState.playerDead ) {
        var endgameNote = checkEndgameTrigger();
        if ( endgameNote.len() ) {
            suffix &= endgameNote;
        }
    }

    return suffix;
}

// One full command clause: charges a turn and runs the tick sequence —
// unless dispatching it only raised a clarifying question (orphan/
// disambiguation), which ZIL doesn't charge a turn for.
function processClauseTurn(clauseWords) {
    gameState.turns += 1;
    var result = dispatchCommand( clauseWords.toList( " " ) );

    if ( gameState.pendingPrompt.type.len() > 0 ) {
        gameState.turns -= 1;
        return result;
    }

    return result & runTickSequence();
}

function processCommand(input) {
    if ( gameState.playerDead ) {
        return "You are dead. The game is over.";
    }
    if ( gameState.gameWon ) {
        return "You have already won. The game is over.";
    }

    // Resume a pending orphan/disambiguation question — the whole line is
    // the answer, not a fresh command.
    if ( gameState.pendingPrompt.type.len() > 0 ) {
        var resumed = resolvePendingPromptTurn( input );
        if ( resumed.stillPending ) {
            return resumed.message;
        }
        gameState.turns += 1;
        return resumed.message & runTickSequence();
    }

    var trimmedLower = input.trim().lcase();
    var inputWords = tokenize( trimmedLower );

    // OOPS <word>: rebuild the last command with its bad word replaced.
    if ( inputWords.len() && inputWords[ 1 ] == "oops" ) {
        if ( inputWords.len() < 2 ) {
            return "Sorry, what word do you want to fix?";
        }
        if ( !gameState.lastUnknownWord.len() || !gameState.lastRawInput.len() ) {
            return "I don't know what to fix.";
        }
        var fixedWord = inputWords[ 2 ];
        var badWord = gameState.lastUnknownWord;
        var rebuiltWords = tokenize( gameState.lastRawInput ).map( (w) => w == badWord ? fixedWord : w );
        gameState.lastUnknownWord = "";
        return processCommand( rebuiltWords.toList( " " ) );
    }

    // AGAIN/G: replay the last fully-dispatched command line verbatim.
    if ( [ "again", "g" ].contains( trimmedLower ) ) {
        if ( !gameState.lastRawInput.len() ) {
            return "I don't know what to repeat yet.";
        }
        return processCommand( gameState.lastRawInput );
    }

    var clauses = splitClauses( input );
    gameState.lastRawInput = input;

    if ( clauses.isEmpty() ) {
        return processClauseTurn( [] );
    }
    if ( clauses.len() == 1 ) {
        return processClauseTurn( clauses[ 1 ] );
    }

    var outputs = [];
    for ( var clause in clauses ) {
        outputs.append( processClauseTurn( clause ) );
        if ( gameState.playerDead || gameState.gameWon || gameState.pendingPrompt.type.len() > 0 ) {
            break;
        }
    }
    return outputs.toList( NEWLINE & NEWLINE );
}

function runDemo() {
    var commands = [
        "look",
        "open mailbox",
        "read leaflet",
        "take leaflet",
        "put leaflet in mailbox",
        "take leaflet",
        "north",
        "east",
        "open window",
        "west",
        "close window",
        "west",
        "take lamp",
        "turn on lamp",
        "turn off lamp",
        "light lamp",
        "take sword",
        "inventory",
        "examine sword",
        "take trophy case",
        "push rug",
        "open trap door",
        "down",
        "north",
        "examine troll",
        "examine axe",
        "attack troll with sword",
        "give leaflet to troll",
        "smell",
        "listen",
        "score",
        "diagnose",
        "south",
        "up",
        "east",
        "up",
        "take rope",
        "take knife",
        "inventory",
        "drink water",
        "xyzzy",
        "take",
        "go"
    ];

    for ( var command in commands ) {
        println( "> " & command );
        println( processCommand( command ) );
        println( "" );
    }
}

function runInteractive() {
    var reader = createObject( "java", "java.io.BufferedReader" ).init(
        createObject( "java", "java.io.InputStreamReader" ).init( createObject( "java", "java.lang.System" ).in )
    );

    println( describeRoom( rooms[ gameState.currentRoom ] ) );
    println( "" );

    while ( true ) {
        print( "> " );
        var line = reader.readLine();
        if ( isNull( line ) ) {
            break;
        }
        line = line.trim();
        if ( line.lcase() == "quit" || line.lcase() == "exit" ) {
            break;
        }
        if ( line.len() == 0 ) {
            continue;
        }
        println( processCommand( line ) );
        println( "" );
        if ( gameState.playerDead || gameState.gameWon ) {
            break;
        }
    }
}

cliArgs = CLIGetArgs().positionals;
if ( cliArgs.len() && cliArgs[ 1 ] == "demo" ) {
    runDemo();
} else {
    loadSave();
    runInteractive();
}
